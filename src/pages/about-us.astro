---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import SEO from "../components/SEO.astro"
import Location from "../components/icons/Location.astro"
import Lifeline from "../components/icons/Lifeline.astro"
import Heart from "../components/icons/Heart.astro"
import ArrowRight from "../components/icons/ArrowRight.astro"
import { getCountries } from "../services/countries"
import "../styles/global.css"

const countriesList = await getCountries()

// Inject a Cloudinary transform after /upload/ (no-op for non-Cloudinary URLs).
const cl = (url: string, t: string) => url.replace('/upload/', `/upload/${t}/`)

const companyMetrics = [
    { value: "2019", label: "Año en que empezamos" },
    { value: "+340", label: "Propiedades acompañadas" },
    { value: String(countriesList.length), label: `Países: ${countriesList.map(c => c.name).join(", ")}` },
    { value: "96%",  label: "Clientes que nos recomiendan" },
]

const companyInfo = [
    { icon: Location, title: "Solo lo rural",  description: "No vendemos pisos en la ciudad. Cada miembro del equipo conoce a fondo el campo, su valor y su comprador." },
    { icon: Lifeline, title: "Honestidad",      description: "Valoraciones realistas y conversaciones francas. Preferimos perder una venta antes que forzarla." },
    { icon: Heart,    title: "Sin prisa",       description: "Esperamos al comprador adecuado. Una casa con alma encuentra a su gente; nuestro trabajo es darle tiempo." },
]

const team = [
    { name: "Lucía Marenco",  role: "Fundadora", img: "https://res.cloudinary.com/dqoqfb8vu/image/upload/v1781379533/lucia_marenco_zrhahs.png",  zone: "Toscana",   bio: "Restauró su primera masía a los 26. No vende una casa que no compraría." },
    { name: "Tomás Ferrer",   role: "Asesor", img: "https://res.cloudinary.com/dqoqfb8vu/image/upload/v1781379532/tomas_ferrer_nujx2y.png", zone: "Pirineos",  bio: "Excursionista y agrónomo. Conoce cada valle por su nombre." },
    { name: "Inès Costa",     role: "Asesora", img: "https://res.cloudinary.com/dqoqfb8vu/image/upload/v1781379533/ines_costa_mvttlh.png", zone: "Alentejo",  bio: "Especialista en quintas y fincas con terreno y agua." },
    { name: "Marc Dubois",    role: "Asesor", img: "https://res.cloudinary.com/dqoqfb8vu/image/upload/v1781379533/marc_dubois_qawcok.png", zone: "Provenza",  bio: "Veinte años entre bastides y campos de lavanda." },
]
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/havre_logo.svg" />
    <link rel="icon" href="/havre_logo.ico" />
    <SEO
        title="Sobre Havre — Quiénes somos y por qué solo lo rural | Havre"
        description="Conoce a Havre: desde 2019 acompañamos la compraventa de casas de campo, fincas y refugios rurales en Europa. Menos casas, mejor contadas."
        image="https://res.cloudinary.com/dqoqfb8vu/image/upload/w_1200,h_830,c_fill,q_auto/f_webp/v1782169782/about-us_hag3n5.png"
    />

    <!-- preconnect to images cdn -->
    <link rel="preconnect" href="https://res.cloudinary.com">

    <!-- connect to domain of font files -->
    <link rel="preconnect" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap' crossorigin>

    <!-- async CSS -->
    <link rel="preload" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap' onload="this.onload=null;this.rel='stylesheet';this.removeAttribute('as')" as="style">

    <!-- no-JS fallback -->
    <noscript>
        <link rel="stylesheet" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap'>
    </noscript>
</head>
<body>
    <Header/>

    <main>
        <section class="hero">
            <p class="hero-main-title">SOBRE HAVRE</p>
            <h1 class="hero-title">
                Un <span>havre</span> es un refugio. Ayudamos a encontrar el tuyo en el campo.
            </h1>

            <p>Nacimos de una idea sencilla: las casas rurales no se venden como los pisos. Tienen historia, tierra y silencio.
                 Merecen contarse con calma y entregarse a quien de verdad sabrá cuidarlas.</p>
            
            <div class="team-img"></div>
        </section>

        <section class="our-history">
            <p>NUESTRA HISTORIA</p>
            <aside>
                <h2>Empezó con una casa de piedra que nadie sabía vender</h2>
                <p>En 2019, buscando una masía abandonada entre olivos, nos topamos con el mismo problema una y otra vez: los grandes portales trataban una casa con doscientos años de historia igual que un estudio en la ciudad. Fotos frías, descripciones de plantilla, y agentes que nunca habían pisado el camino de tierra.</p>
                <p>Pensamos que lo rural merecía otra cosa. Una inmobiliaria que conociera la diferencia entre un olivar en producción y uno abandonado, que supiera por qué importa la orientación del porche, y que tuviera la paciencia de esperar al comprador correcto en lugar del primero.</p>
                <p>Hoy somos un equipo pequeño repartido por tres países, pero la idea sigue intacta: <span>menos casas, mejor contadas</span>.</p>
            </aside>
        </section>

        <section class="company-info">
            <h2>Lo que nos guía</h2>

            <div class="cards">
                { companyInfo.map(item => (
                    <article>
                        <item.icon />
                        <h3>{item.title}</h3>
                        <p>{item.description}</p>
                    </article>
                )) }
            </div>

            <article class="company-metrics">
                { companyMetrics.map(metric => (
                    <div>
                        <p>{metric.value}</p>
                        <h2>{metric.label}</h2>
                    </div>
                )) }
            </article>
        </section>

        <section class="team">
            <p>EL EQUIPO</p>
            <h2>Gente que conoce el camino de tierra</h2>
            { team.map(member => (
                <article class="partner">
                    <div class="image" style={`--img: url(${cl(member.img, 'f_auto,q_auto,w_500')})`}></div>
                    <h3>{member.name}</h3>
                    <h4>{member.role} · {member.zone}</h4>
                    <p>{member.bio}</p>
                </article>
            )) }
        </section>

        <article class="slogan">
            <p class="slogan-quote">“No vendemos propiedades. Acompañamos a las personas hasta el lugar donde querrán quedarse.”</p>
            <p class="slogan-eyebrow">LA PROMESA HAVRE</p>
        </article>

        <section class="cta-nav">
            <a href="/comprar">
                <h2>Explorar propiedades</h2>
                <p>Más de 340 casas de campo, fincas y refugios esperándote.</p>
                <span>Ver el catálogo <ArrowRight/></span>
            </a>

            <a href="/vender">
                <h2>Vender con nosotros</h2>
                <p>Valoración gratuita y acompañamiento de principio a fin.</p>
                <span>Empezar <ArrowRight/></span>
            </a>
        </section>
    </main>

    <Footer/>
</body>
</html>

<style>
    main {
        max-width: calc(var(--max-width) + 80px);
        padding: 0px calc(var(--havre-space-5) * 4);
        margin: 0 auto;
  }

    .hero {
        padding: 80px 0;
    }

    .hero-main-title {
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-small);
        font-weight: var(--havre-weight-semibold);
        letter-spacing: var(--havre-tracking-eyebrow);
        color: var(--havre-link);
        margin: 0 0 28px;
    }

    .hero-title {
        font-family: var(--havre-font-serif);
        font-size: var(--havre-text-display);
        font-weight: var(--havre-weight-bold);
        line-height: var(--havre-leading-heading);
        color: var(--havre-ink-900);
        margin: 0 0 32px;
        max-width: 980px;

        span {
            color: var(--havre-link);
            font-style: italic;
        }
    }

    .hero > p {
        font-size: 21px;
        color: var(--havre-ink-700);
        line-height: var(--havre-leading-body);
        max-width: 680px;
        margin: 0 0 56px;
    }

    .our-history {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 64px;
        padding: 80px 0;
        border-top: 1px solid var(--havre-line);
    }

    .our-history > p {
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-small);
        font-weight: var(--havre-weight-semibold);
        letter-spacing: var(--havre-tracking-eyebrow);
        color: var(--havre-link);
        margin: 6px 0 0;
    }

    .our-history aside h2 {
        font-family: var(--havre-font-serif);
        font-size: var(--havre-text-h2);
        font-weight: var(--havre-weight-regular);
        line-height: var(--havre-leading-snug);
        color: var(--havre-ink-900);
        margin: 0 0 32px;
    }

    .our-history aside p {
        font-size: var(--havre-text-subtitle);
        color: var(--havre-ink-700);
        line-height: var(--havre-leading-body);
        margin: 0 0 20px;

        span {
            font-weight: var(--havre-weight-semibold);
            color: var(--havre-link);
        }
    }

    .company-info {
        padding: 80px 0;
        border-top: 1px solid var(--havre-line);
    }

    .company-info > h2 {
        font-family: var(--havre-font-serif);
        font-size: var(--havre-text-h2);
        font-weight: var(--havre-weight-bold);
        color: var(--havre-ink-900);
        margin: 0 0 40px;
    }

    .cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }

    .cards article {
        background-color: var(--havre-white);
        border: 1px solid var(--havre-border-card);
        border-radius: var(--havre-radius-xl);
        padding: 32px;
        box-shadow: var(--havre-shadow-xs);

        h3 {
            font-family: var(--havre-font-serif);
            font-size: var(--havre-text-h3);
            font-weight: var(--havre-weight-semibold);
            color: var(--havre-ink-900);
            margin: 24px 0 12px;
        }

        p {
            font-size: var(--havre-text-body);
            color: var(--havre-text-muted);
            line-height: var(--havre-leading-body);
            margin: 0;
        }

        svg {
            display: block;
            padding: 10px;
            background-color: var(--havre-papaya);
            color: var(--havre-bronze-text);
            border-radius: var(--havre-radius-md);
            width: 48px;
            height: 48px;
        }
    }

    .company-metrics {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        background-color: var(--havre-ink-900);
        border-radius: var(--havre-radius-2xl);
        padding: 52px 56px;

        div {
            padding: 0 40px;

            &:first-child { padding-left: 0; }
            &:last-child  { border-right: none; }
        }

        p {
            font-family: var(--havre-font-serif);
            font-size: var(--havre-text-h1);
            font-weight: var(--havre-weight-regular);
            color: var(--havre-cornsilk);
            margin: 0 0 15px;
            line-height: 1;
        }

        h2 {
            font-size: var(--havre-text-small);
            color: var(--havre-ink-300);
            font-weight: var(--havre-weight-semibold);
            margin: 0;
            line-height: var(--havre-leading-snug);
        }
    }

    .team-img {
        width: 100%;
        height: 440px;
        background:
            linear-gradient(rgba(46, 42, 32, 0) 0%, rgba(46, 42, 32, 0) 60%, rgba(46, 42, 32, .8) 100%),
            linear-gradient(rgba(110, 122, 78, 0) 0%, rgba(101, 114, 70, .2) 30%, rgba(101, 114, 70, 1) 100%),
            url(https://res.cloudinary.com/dqoqfb8vu/image/upload/f_auto,q_auto,w_1280/v1781375621/team-bg_tlcfku.webp) center / cover no-repeat;
        border-radius: var(--havre-radius-2xl);
        position: relative;
        overflow: hidden;
        
        &::after {
            content: "El equipo en una masía de la Toscana, 2024";
            position: absolute;
            bottom: 24px;
            left: 28px;
            font-family: var(--havre-font-sans);
            font-size: var(--havre-text-label);
            color: rgba(255, 255, 255, 0.55);
        }
    }

    .team {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        column-gap: 24px;
        padding: 80px 0;
        border-top: 1px solid var(--havre-line);
    }

    .team > p {
        grid-column: 1 / -1;
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-small);
        font-weight: var(--havre-weight-semibold);
        letter-spacing: var(--havre-tracking-eyebrow);
        color: var(--havre-link);
        margin: 0 0 16px;
    }

    .team > h2 {
        grid-column: 1 / -1;
        font-family: var(--havre-font-serif);
        font-size: var(--havre-text-h1);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-ink-900);
        margin: 0 0 40px;
        line-height: var(--havre-leading-heading);
    }

    .partner .image {
        width: 100%;
        aspect-ratio: 3.5 / 5;
        background:
            linear-gradient(rgba(46, 42, 32, 0) 0%, rgba(46, 42, 32, 0) 55%, rgba(46, 42, 32, .55) 100%),
            linear-gradient(rgba(110, 122, 78, 0) 0%, rgba(101, 114, 70, .15) 40%, rgba(101, 114, 70, .6) 100%),
            var(--img) center / cover no-repeat;
        border-radius: var(--havre-radius-xl);
        margin-bottom: 20px;
    }

    .partner h3 {
        font-family: var(--havre-font-serif);
        font-size: calc(var(--havre-text-h3) * .9);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-ink-900);
        margin: 0 0 4px;
    }

    .partner h4 {
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-small);
        font-weight: var(--havre-weight-medium);
        color: var(--havre-bronze-text);
        margin: 0 0 12px;
    }

    .partner p {
        font-size: var(--havre-text-small);
        color: var(--havre-ink-700);
        line-height: var(--havre-leading-body);
        margin: 0;
    }

    .slogan {
        background-color: var(--havre-beige);
        border-radius: var(--havre-radius-2xl);
        padding: 80px 80px;
        text-align: center;
        margin: 0 0 70px;
    }

    .slogan-quote {
        font-family: var(--havre-font-serif);
        font-size: var(--havre-text-h2);
        font-style: italic;
        font-weight: var(--havre-weight-regular);
        color: var(--havre-ink-900);
        line-height: var(--havre-leading-snug);
        margin: 0 0 28px;
        max-width: 780px;
        margin-left: auto;
        margin-right: auto;
    }

    .slogan-eyebrow {
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-small);
        font-weight: var(--havre-weight-semibold);
        letter-spacing: var(--havre-tracking-eyebrow);
        color: var(--havre-ink-500);
        margin: 0;
    }

    .cta-nav {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        padding: 24px 0 100px;
    }

    .cta-nav > a {
        display: flex;
        flex-direction: column;
        background-color: var(--havre-white);
        border: 1px solid var(--havre-border-card);
        border-radius: var(--havre-radius-xl);
        padding: 40px 40px 36px;
        transition: all ease-in .15s;

        h2 {
            font-family: var(--havre-font-serif);
            font-size: calc(var(--havre-text-h2) * .85);
            font-weight: var(--havre-weight-regular);
            color: var(--havre-ink-900);
            margin: 0 0 12px;
        }

        p {
            font-size: var(--havre-text-body);
            color: var(--havre-ink-500);
            line-height: var(--havre-leading-body);
            margin: 0 0 28px;
        }

        span {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: var(--havre-text-small);
            font-weight: var(--havre-weight-semibold);
            color: var(--havre-bronze-text);
            margin-top: auto;
        }
    }

    .cta-nav > a:hover {
        transform: translateY(-5px);
        box-shadow: var(--havre-shadow-xl);
    }

    @media (max-width: 749px) {
        main { padding: 0 20px; }

        .hero { padding: 48px 0; }
        .hero-title { font-size: var(--havre-text-h1); }
        .hero > p   { font-size: var(--havre-text-body); max-width: none; }
        .team-img   { height: 300px; }

        .our-history {
            grid-template-columns: 1fr;
            gap: 20px;
            padding: 48px 0;
        }
        .our-history > p  { margin: 0; }
        .our-history aside h2 { font-size: var(--havre-text-h3); }
        .our-history aside p  { font-size: var(--havre-text-body); }

        .company-info { padding: 48px 0; }
        .cards { grid-template-columns: 1fr; }

        .company-metrics {
            grid-template-columns: 1fr 1fr;
            padding: 36px 32px;
            gap: 32px;
        }
        .company-metrics div {
            padding: 0;
            border-right: none;
        }

        .team {
            grid-template-columns: repeat(2, 1fr);
            row-gap: 40px;
            padding: 48px 0;
        }

        .slogan { padding: 48px 28px; margin-bottom: 40px; }
        .slogan-quote { font-size: var(--havre-text-h3); }

        .cta-nav { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
        main { padding: 0 16px; }

        .hero { padding: 36px 0; }
        .hero-title { font-size: var(--havre-text-h2); }
        .team-img   { height: 220px; }

        .company-metrics {
            grid-template-columns: 1fr;
            padding: 32px 28px;
        }

        .team { column-gap: 16px; }

        .slogan { padding: 36px 20px; }
        .slogan-quote { font-size: var(--havre-text-subtitle); }

        .cta-nav > a { padding: 28px 24px; }
    }
</style>