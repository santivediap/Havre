---
import "../styles/global.css"
import Header from "../components/Header.astro"
import Users from "../components/icons/Users.astro"
import Map from "../components/icons/Map.astro"
import Home from "../components/icons/Home.astro"
import Calendar from "../components/icons/Calendar.astro"
import Logout from "../components/icons/Logout.astro"
import Edit from "../components/icons/Edit.astro"
import Trash from "../components/icons/Trash.astro"
import { getSession } from "../lib/auth"
import { getUserById, getUsers } from "../services/users"
import { getZonesAdmin } from "../services/zones"
import { getCountries } from "../services/countries"
import { getProperties } from "../services/properties"
import { getVisitRequests } from "../services/visitRequests"

const session = await getSession(Astro.cookies)
if (!session) return Astro.redirect('/login')

const me = await getUserById(session.sub)
if (!me) return Astro.redirect('/login')

const isAdmin = session.role === 'admin'
const [zonesList, propertiesList, countriesList, visitRequestsList] = await Promise.all([getZonesAdmin(), getProperties(), getCountries(), getVisitRequests()])
const usersList = isAdmin ? await getUsers() : []
const tones = ['olive', 'bronze', 'sage'] as const
const toneFor = (i: number) => tones[i % tones.length]

const initials = (name: string) =>
    name.trim().split(/\s+/).slice(0, 2).map(w => w[0]?.toUpperCase() ?? '').join('')

const roleLabel = (role: string) => role === 'admin' ? 'Administrador' : 'Agente'

const monthYear = (date: Date | string) =>
    new Intl.DateTimeFormat('es-ES', { month: 'short', year: 'numeric' }).format(new Date(date))

const formatPrice = (price: number) => `€ ${new Intl.NumberFormat('es-ES').format(price)}`

function userStatus(u: { is_active: boolean; last_login_at: Date | string | null }) {
    if (!u.is_active)     return { label: 'Inactivo', cls: 'status--invited' }
    if (!u.last_login_at) return { label: 'Invitado', cls: 'status--invited' }
    return { label: 'Activo', cls: 'status--active' }
}

const propertyStatusLabel: Record<string, string> = {
    draft: 'Borrador', published: 'Publicado', archived: 'Archivado',
}

const visitStatusLabel: Record<string, string> = {
    pending: 'Pendiente', contacted: 'Contactado', closed: 'Cerrado',
}
const visitStatusOrder = ['pending', 'contacted', 'closed'] as const

const preferredDateLabel: Record<string, string> = {
    'this-week': 'Esta semana', 'next-week': 'La próxima semana',
    'this-month': 'Este mes', 'flexible': 'Sin preferencia',
}

const shortDate = (date: Date | string) =>
    new Intl.DateTimeFormat('es-ES', { day: 'numeric', month: 'short' }).format(new Date(date))
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/havre_logo.svg" />
    <link rel="icon" href="/havre_logo.ico" />
    <meta name="robots" content="noindex, nofollow">
    <title>Panel de administración | Havre</title>
    <meta name="description" content="Panel interno de Havre para la gestión de usuarios, zonas y propiedades.">

    <!-- connect to domain of font files -->
    <link rel="preconnect" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap' crossorigin>

    <!-- async CSS -->
    <link rel="preload" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap' onload="this.onload=null;this.rel='stylesheet';this.removeAttribute('as')" as="style">

    <!-- no-JS fallback -->
    <noscript>
        <link rel="stylesheet" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap'>
    </noscript>
</head>
<body>

    <Header />

    <main class="admin">

        <section class="profile-card" aria-label="Perfil del usuario">
            <div class="profile-identity">
                <span class="avatar avatar--lg avatar--olive" aria-hidden="true">
                    { me.avatar_url ? <img src={me.avatar_url} alt="" /> : initials(me.name) }
                </span>
                <div>
                    <h1>
                        {me.name}
                        <span class={`badge badge--dot ${isAdmin ? "badge--admin" : "badge--agent"}`}>{roleLabel(me.role)}</span>
                    </h1>
                    <p class="profile-email">{me.email}</p>
                    <p class="profile-since">En Havre desde {monthYear(me.created_at)}</p>
                </div>
            </div>
        </section>

        <div class="admin-body">

            <aside class="admin-sidebar" aria-label="Secciones del panel">
                <nav class="sidebar-nav">
                    <ul>
                        { isAdmin && (
                            <li>
                                <a href="#usuarios" class="is-active" aria-current="page">
                                    <Users /> <span>Usuarios</span> <em>{usersList.length}</em>
                                </a>
                            </li>
                        ) }
                        <li>
                            <a href="#zonas" class={!isAdmin ? "is-active" : ""} aria-current={!isAdmin ? "page" : undefined}>
                                <Map /> <span>Zonas</span> <em>{zonesList.length}</em>
                            </a>
                        </li>
                        <li>
                            <a href="#propiedades">
                                <Home /> <span>Propiedades</span> <em>{propertiesList.length}</em>
                            </a>
                        </li>
                        <li>
                            <a href="#solicitudes">
                                <Calendar /> <span>Solicitudes</span> <em>{visitRequestsList.length}</em>
                            </a>
                        </li>
                    </ul>
                </nav>

                <button type="button" class="logout-link" id="logout-btn"><Logout /> Cerrar sesión</button>
            </aside>

            <div class="panels">

                { isAdmin && (
                    <section class="panel" id="usuarios" aria-labelledby="users-heading">
                        <div class="panel-header">
                            <div>
                                <h2 id="users-heading">Usuarios del equipo</h2>
                                <p>Da de alta, edita roles o retira el acceso de cada persona.</p>
                            </div>
                            <button type="button" class="new-user-btn" id="open-new-user"><span aria-hidden="true">+</span> Nuevo usuario</button>
                        </div>

                        <ul class="user-list" role="list">
                            { usersList.length === 0 && <li class="empty">Aún no hay usuarios.</li> }
                            { usersList.map((user, i) => {
                                const status = userStatus(user)
                                return (
                                    <li class="user-row">
                                        <span class={`avatar avatar--${toneFor(i)}`} aria-hidden="true">
                                            { user.avatar_url
                                                ? <img src={user.avatar_url} alt="" />
                                                : initials(user.name) }
                                        </span>

                                        <div class="user-identity">
                                            <p class="user-name">
                                                {user.name}
                                                <span class={`badge ${user.role === "admin" ? "badge--admin" : "badge--agent"}`}>{roleLabel(user.role)}</span>
                                            </p>
                                            <p class="user-email">{user.email}</p>
                                        </div>

                                        <div class="user-meta">
                                            <span class="meta-value">{user.last_login_at ? monthYear(user.last_login_at) : "—"}</span>
                                            <span class="meta-label">último acceso</span>
                                        </div>

                                        <div class="user-meta">
                                            <span class={`meta-value ${status.cls}`}>{status.label}</span>
                                            <span class="meta-label">estado</span>
                                        </div>

                                        <div class="user-actions">
                                            <button type="button" class="icon-btn"
                                                data-edit-user={user.id}
                                                data-name={user.name}
                                                data-email={user.email}
                                                data-phone={user.phone ?? ''}
                                                data-role={user.role}
                                                data-active={String(user.is_active)}
                                                data-self={user.id === me.id ? 'true' : 'false'}
                                                data-avatar={user.avatar_url ?? ''}
                                                aria-label={`Editar ${user.name}`}><Edit /></button>
                                            { user.id !== me.id && (
                                                <button type="button" class="icon-btn icon-btn--danger" data-delete-user={user.id} data-user-name={user.name} aria-label={`Eliminar ${user.name}`}><Trash /></button>
                                            ) }
                                        </div>
                                    </li>
                                )
                            }) }
                        </ul>
                    </section>
                ) }

                <section class="panel" id="zonas" aria-labelledby="zones-heading">
                    <div class="panel-header">
                        <div>
                            <h2 id="zones-heading">Zonas</h2>
                            <p>Las regiones rurales publicadas en la web.</p>
                        </div>
                        <button type="button" class="new-user-btn" id="open-new-zone"><span aria-hidden="true">+</span> Nueva zona</button>
                    </div>

                    <ul class="user-list" role="list">
                        { zonesList.length === 0 && <li class="empty">Aún no hay zonas.</li> }
                        { zonesList.map((zone, i) => (
                            <li class={`user-row ${zone.is_active ? "" : "is-inactive"}`}>
                                <span class={`avatar avatar--${toneFor(i)}`} aria-hidden="true">
                                    { zone.image_url
                                        ? <img src={zone.image_url} alt="" />
                                        : initials(zone.name) }
                                </span>

                                <div class="user-identity">
                                    <p class="user-name">{zone.name}</p>
                                    <p class="user-country">{zone.country.toUpperCase()}</p>
                                </div>

                                <div class="user-meta">
                                    <span class="meta-value">{zone.count}</span>
                                    <span class="meta-label">activas</span>
                                </div>

                                <div class="user-meta">
                                    <span class="meta-value">{zone.price_from ? formatPrice(zone.price_from) : "—"}</span>
                                    <span class="meta-label">desde</span>
                                </div>

                                <div class="user-actions">
                                    <button type="button" class="icon-btn"
                                        data-edit-zone={zone.id}
                                        data-name={zone.name}
                                        data-country={zone.country_id}
                                        data-slug={zone.slug}
                                        data-description={zone.description ?? ''}
                                        data-tags={zone.tags?.join(', ') ?? ''}
                                        data-order={zone.display_order}
                                        data-active={String(zone.is_active)}
                                        data-image={zone.image_url ?? ''}
                                        aria-label={`Editar ${zone.name}`}><Edit /></button>
                                    <button type="button" class="icon-btn icon-btn--danger" data-delete-zone={zone.id} data-zone-name={zone.name} aria-label={`Eliminar ${zone.name}`}><Trash /></button>
                                </div>
                            </li>
                        )) }
                    </ul>
                </section>

                <section class="panel" id="propiedades" aria-labelledby="properties-heading">
                    <div class="panel-header">
                        <div>
                            <h2 id="properties-heading">Propiedades</h2>
                            <p>El catálogo de fincas y casas de campo.</p>
                        </div>
                        <button type="button" class="new-user-btn" id="open-new-property"><span aria-hidden="true">+</span> Nueva propiedad</button>
                    </div>

                    <ul class="user-list" role="list">
                        { propertiesList.length === 0 && <li class="empty">Aún no hay propiedades.</li> }
                        { propertiesList.map((property, i) => (
                            <li class="user-row">
                                <span class={`avatar avatar--${toneFor(i)}`} aria-hidden="true">{initials(property.title)}</span>

                                <div class="user-identity">
                                    <p class="user-name">
                                        {property.title}
                                        <span class={`badge badge--${property.status}`}>{propertyStatusLabel[property.status]}</span>
                                    </p>
                                    <p class="user-email">{property.zone} · {property.reference}</p>
                                </div>

                                <div class="user-meta">
                                    <span class="meta-value">{formatPrice(property.price)}</span>
                                    <span class="meta-label">precio</span>
                                </div>

                                <div class="user-meta">
                                    <span class="meta-value">{property.agent}</span>
                                    <span class="meta-label">asesor</span>
                                </div>

                                <div class="user-actions">
                                    <button type="button" class="icon-btn" data-edit-property={property.id} aria-label={`Editar ${property.title}`}><Edit /></button>
                                    <button type="button" class="icon-btn icon-btn--danger" data-delete-property={property.id} data-title={property.title} aria-label={`Eliminar ${property.title}`}><Trash /></button>
                                </div>
                            </li>
                        )) }
                    </ul>
                </section>

                <section class="panel" id="solicitudes" aria-labelledby="visits-heading">
                    <div class="panel-header">
                        <div>
                            <h2 id="visits-heading">Solicitudes de visita</h2>
                            <p>Las peticiones de visita recibidas desde las fichas de propiedad.</p>
                        </div>
                    </div>

                    <ul class="user-list" role="list">
                        { visitRequestsList.length === 0 && <li class="empty">Aún no hay solicitudes de visita.</li> }
                        { visitRequestsList.map((req, i) => (
                            <li class="user-row" data-visit-row={req.id}>
                                <span class={`avatar avatar--${toneFor(i)}`} aria-hidden="true">{initials(req.name)}</span>

                                <div class="user-identity">
                                    <p class="user-name">
                                        {req.name}
                                        <span class={`badge badge--visit-${req.status}`} data-visit-badge>{visitStatusLabel[req.status]}</span>
                                    </p>
                                    <p class="user-email">
                                        <a href={`/comprar/${req.property_slug}`} target="_blank" rel="noopener">{req.property_title}</a>
                                    </p>
                                </div>

                                <div class="user-meta">
                                    <span class="meta-value">{req.contact}</span>
                                    <span class="meta-label">contacto</span>
                                </div>

                                <div class="user-meta">
                                    <span class="meta-value">{req.preferred_date ? (preferredDateLabel[req.preferred_date] ?? req.preferred_date) : "—"}</span>
                                    <span class="meta-label">{shortDate(req.created_at)}</span>
                                </div>

                                <div class="user-actions">
                                    <label class="sr-only" for={`visit-status-${req.id}`}>Estado de la solicitud de {req.name}</label>
                                    <select class="visit-status" id={`visit-status-${req.id}`} data-visit-status={req.id}>
                                        { visitStatusOrder.map(s => (
                                            <option value={s} selected={s === req.status}>{visitStatusLabel[s]}</option>
                                        )) }
                                    </select>
                                    <button type="button" class="icon-btn icon-btn--danger" data-delete-visit={req.id} data-visit-name={req.name} aria-label={`Eliminar la solicitud de ${req.name}`}><Trash /></button>
                                </div>
                            </li>
                        )) }
                    </ul>
                </section>

            </div>
        </div>

        { isAdmin && (
            <dialog class="modal" id="new-user-modal" aria-labelledby="nu-title">
                <div class="modal-head">
                    <div>
                        <h2 id="nu-title">Nuevo usuario</h2>
                    </div>
                    <button type="button" class="modal-close" id="nu-close" aria-label="Cerrar">&times;</button>
                </div>

                <form class="modal-form" id="new-user-form" novalidate>
                    <div class="avatar-upload">
                        <span class="avatar avatar--lg avatar--olive" id="nu-avatar-preview" aria-hidden="true"></span>
                        <div>
                            <label class="upload-btn" for="nu-avatar">Subir foto</label>
                            <input type="file" id="nu-avatar" name="avatar" accept="image/*" hidden />
                            <p class="upload-hint">JPG o PNG · máx. 2 MB</p>
                        </div>
                    </div>

                    <div class="modal-field">
                        <label for="nu-name">Nombre completo</label>
                        <input type="text" id="nu-name" name="name" placeholder="Nombre y apellidos" aria-describedby="nu-name-error" required />
                        <p class="field-error" id="nu-name-error" role="alert"></p>
                    </div>

                    <div class="modal-field">
                        <label for="nu-email">Correo</label>
                        <input type="email" id="nu-email" name="email" placeholder="nombre@havre.com" autocomplete="off" aria-describedby="nu-email-error" required />
                        <p class="field-error" id="nu-email-error" role="alert"></p>
                    </div>

                    <div class="modal-field">
                        <label for="nu-phone">Teléfono <span class="field-optional">(opcional)</span></label>
                        <input type="tel" id="nu-phone" name="phone" placeholder="+34 600 000 000" autocomplete="off" />
                    </div>

                    <div class="modal-field">
                        <label for="nu-password">Contraseña</label>
                        <input type="password" id="nu-password" name="password" placeholder="Mínimo 8 caracteres" autocomplete="new-password" aria-describedby="nu-password-error" required />
                        <p class="field-error" id="nu-password-error" role="alert"></p>
                    </div>

                    <div class="modal-field">
                        <label for="nu-role">Rol</label>
                        <select id="nu-role" name="role">
                            <option value="agent">Agente</option>
                            <option value="admin">Administrador</option>
                        </select>
                    </div>

                    <div class="modal-field" id="nu-status-field" hidden>
                        <label for="nu-status">Estado</label>
                        <select id="nu-status" name="is_active">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                    <p class="form-error" id="nu-form-error" role="alert"></p>

                    <div class="modal-actions">
                        <button type="button" class="btn-secondary" id="nu-cancel">Cancelar</button>
                        <button type="submit" class="btn-primary">Crear</button>
                    </div>
                </form>
            </dialog>
        ) }

        <dialog class="modal" id="new-zone-modal" aria-labelledby="nz-title">
            <div class="modal-head">
                <div>
                    <h2 id="nz-title">Nueva zona</h2>
                </div>
                <button type="button" class="modal-close" id="nz-close" aria-label="Cerrar">&times;</button>
            </div>

            <form class="modal-form" id="new-zone-form" novalidate>
                <div class="avatar-upload">
                    <span class="zone-thumb" id="nz-image-preview" aria-hidden="true"></span>
                    <div>
                        <label class="upload-btn" for="nz-image">Subir imagen</label>
                        <input type="file" id="nz-image" name="image" accept="image/*" hidden />
                        <p class="upload-hint">JPG o PNG · máx. 5 MB</p>
                    </div>
                </div>

                <div class="modal-field">
                    <label for="nz-name">Nombre</label>
                    <input type="text" id="nz-name" name="name" placeholder="Toscana" aria-describedby="nz-name-error" required />
                    <p class="field-error" id="nz-name-error" role="alert"></p>
                </div>

                <div class="modal-field">
                    <label for="nz-country">País</label>
                    <select id="nz-country" name="country_id">
                        { countriesList.map(country => (
                            <option value={country.id}>{country.name}</option>
                        )) }
                    </select>
                </div>

                <div class="modal-field">
                    <label for="nz-slug">Slug <span class="field-optional">(se genera del nombre si lo dejas vacío)</span></label>
                    <input type="text" id="nz-slug" name="slug" placeholder="toscana" autocomplete="off" />
                </div>

                <div class="modal-field">
                    <label for="nz-description">Descripción <span class="field-optional">(opcional)</span></label>
                    <textarea id="nz-description" name="description" rows="3" placeholder="Colinas de olivos y cipreses, masías de piedra..."></textarea>
                </div>

                <div class="modal-field">
                    <label for="nz-tags">Tags <span class="field-optional">(separados por comas)</span></label>
                    <input type="text" id="nz-tags" name="tags" placeholder="Olivares, Masías, Viñedos" autocomplete="off" />
                </div>

                <div class="modal-field">
                    <label for="nz-order">Orden <span class="field-optional">(menor aparece antes)</span></label>
                    <input type="number" id="nz-order" name="display_order" min="0" placeholder="0" />
                </div>

                <div class="modal-field" id="nz-status-field" hidden>
                    <label for="nz-status">Estado</label>
                    <select id="nz-status" name="is_active">
                        <option value="true">Activa</option>
                        <option value="false">Inactiva</option>
                    </select>
                </div>

                <p class="form-error" id="nz-form-error" role="alert"></p>

                <div class="modal-actions">
                    <button type="button" class="btn-secondary" id="nz-cancel">Cancelar</button>
                    <button type="submit" class="btn-primary">Crear</button>
                </div>
            </form>
        </dialog>

        <dialog class="modal" id="new-property-modal" aria-labelledby="np-title">
            <div class="modal-head">
                <div>
                    <h2>Nueva propiedad</h2>
                </div>
                <button type="button" class="modal-close" id="np-close" aria-label="Cerrar">&times;</button>
            </div>

            <form class="modal-form" id="new-property-form" novalidate>
                <div class="modal-field">
                    <label for="np-title">Título</label>
                    <input type="text" id="np-title" name="title" placeholder="Masía entre olivares" aria-describedby="np-title-error" required />
                    <p class="field-error" id="np-title-error" role="alert"></p>
                </div>

                <div class="modal-field">
                    <label for="np-zone">Zona</label>
                    <select id="np-zone" name="zone_id">
                        { zonesList.map(zone => (
                            <option value={zone.id}>{zone.name} · {zone.country}</option>
                        )) }
                    </select>
                </div>

                { isAdmin && (
                    <div class="modal-field">
                        <label for="np-agent">Asesor responsable</label>
                        <select id="np-agent" name="agent_id">
                            { usersList.map(user => (
                                <option value={user.id} selected={user.id === me.id}>{user.name}</option>
                            )) }
                        </select>
                    </div>
                ) }

                <div class="modal-field">
                    <label for="np-price">Precio (€)</label>
                    <input type="number" id="np-price" name="price" min="0" placeholder="685000" aria-describedby="np-price-error" required />
                    <p class="field-error" id="np-price-error" role="alert"></p>
                </div>

                <div class="modal-row">
                    <div class="modal-field">
                        <label for="np-beds">Habitaciones</label>
                        <input type="number" id="np-beds" name="n_beds" min="0" placeholder="4" required />
                    </div>
                    <div class="modal-field">
                        <label for="np-baths">Baños</label>
                        <input type="number" id="np-baths" name="n_baths" min="0" placeholder="2" required />
                    </div>
                </div>

                <div class="modal-row">
                    <div class="modal-field">
                        <label for="np-built">Construidos (m²)</label>
                        <input type="number" id="np-built" name="m_built" min="0" placeholder="320" required />
                    </div>
                    <div class="modal-field">
                        <label for="np-terrain">Terreno (ha) <span class="field-optional">(opcional)</span></label>
                        <input type="number" id="np-terrain" name="terrain_space" min="0" step="0.01" placeholder="1.2" />
                    </div>
                </div>

                <div class="modal-row">
                    <div class="modal-field">
                        <label for="np-tag">Etiqueta</label>
                        <select id="np-tag" name="tag">
                            <option value="for_sale">En venta</option>
                            <option value="new">Nuevo</option>
                            <option value="reserved">Reservado</option>
                            <option value="sold">Vendido</option>
                        </select>
                    </div>
                    <div class="modal-field">
                        <label for="np-status">Estado</label>
                        <select id="np-status" name="status">
                            <option value="draft">Borrador</option>
                            <option value="published">Publicado</option>
                            <option value="archived">Archivado</option>
                        </select>
                    </div>
                </div>

                <div class="modal-field">
                    <label for="np-description">Descripción <span class="field-optional">(opcional)</span></label>
                    <textarea id="np-description" name="description" rows="3" placeholder="Entre suaves colinas plantadas de olivos centenarios..."></textarea>
                </div>

                <div class="modal-field">
                    <label for="np-features">Características <span class="field-optional">(separadas por comas)</span></label>
                    <input type="text" id="np-features" name="features" placeholder="Piscina, Chimenea de leña, Pozo de agua" autocomplete="off" />
                </div>

                <div class="modal-field">
                    <label for="np-distances">Distancias <span class="field-optional">(una por línea: valor unidad etiqueta)</span></label>
                    <textarea id="np-distances" name="distances" rows="3" placeholder="4 km al pueblo&#10;18 km a Siena&#10;35 min al aeropuerto"></textarea>
                </div>

                <div class="modal-row">
                    <div class="modal-field">
                        <label for="np-lat">Latitud <span class="field-optional">(opcional)</span></label>
                        <input type="number" id="np-lat" name="latitude" step="any" placeholder="43.318" />
                    </div>
                    <div class="modal-field">
                        <label for="np-lng">Longitud <span class="field-optional">(opcional)</span></label>
                        <input type="number" id="np-lng" name="longitude" step="any" placeholder="11.330" />
                    </div>
                </div>

                <label class="check-field">
                    <input type="checkbox" id="np-featured" name="is_featured" value="true" />
                    <span>Destacar en portada</span>
                </label>

                <div class="modal-field photo-manager">
                    <label>Fotos <span class="field-optional">(máx. 10 · arrastra para reordenar, la primera es la portada)</span></label>
                    <label class="upload-btn" for="np-photos" id="np-photos-label">Subir fotos</label>
                    <input type="file" id="np-photos" accept="image/*" multiple hidden />
                    <ul class="photo-list" id="np-photo-list"></ul>
                </div>

                <p class="form-error" id="np-form-error" role="alert"></p>

                <div class="modal-actions">
                    <button type="button" class="btn-secondary" id="np-cancel">Cancelar</button>
                    <button type="submit" class="btn-primary">Crear</button>
                </div>
            </form>
        </dialog>

        <dialog class="confirm-modal" id="confirm-modal" aria-labelledby="confirm-title">
            <div class="confirm-icon" aria-hidden="true"><Trash /></div>
            <h2 class="confirm-title" id="confirm-title">Confirmar</h2>
            <p class="confirm-message" id="confirm-message"></p>
            <div class="confirm-actions">
                <button type="button" class="btn-secondary" id="confirm-cancel">Cancelar</button>
                <button type="button" class="btn-danger" id="confirm-accept">Eliminar</button>
            </div>
        </dialog>
    </main>

</body>
</html>

<script>
    const confirmModal     = document.querySelector<HTMLDialogElement>('#confirm-modal');
    const confirmTitle     = document.querySelector<HTMLElement>('#confirm-title');
    const confirmMessage   = document.querySelector<HTMLElement>('#confirm-message');
    const confirmAcceptBtn = document.querySelector<HTMLButtonElement>('#confirm-accept');
    const confirmCancelBtn = document.querySelector<HTMLButtonElement>('#confirm-cancel');

    function askConfirm(opts: { title?: string; message: string; confirmLabel?: string }): Promise<boolean> {
        return new Promise(resolve => {
            if (!confirmModal) { resolve(false); return; }

            if (confirmTitle)     confirmTitle.textContent     = opts.title ?? 'Confirmar';
            if (confirmMessage)   confirmMessage.textContent   = opts.message;
            if (confirmAcceptBtn) confirmAcceptBtn.textContent = opts.confirmLabel ?? 'Eliminar';

            const cleanup = () => {
                confirmAcceptBtn?.removeEventListener('click', onAccept);
                confirmCancelBtn?.removeEventListener('click', onCancel);
                confirmModal.removeEventListener('cancel', onCancel);
                confirmModal.removeEventListener('click', onBackdrop);
            };
            const onAccept   = () => { cleanup(); confirmModal.close(); resolve(true); };
            const onCancel   = () => { cleanup(); confirmModal.close(); resolve(false); };
            const onBackdrop = (event: MouseEvent) => { if (event.target === confirmModal) onCancel(); };

            confirmAcceptBtn?.addEventListener('click', onAccept);
            confirmCancelBtn?.addEventListener('click', onCancel);
            confirmModal.addEventListener('cancel', onCancel);
            confirmModal.addEventListener('click', onBackdrop);
            confirmModal.showModal();
        });
    }

    const navLinks = document.querySelectorAll<HTMLAnchorElement>('.sidebar-nav a');
    const panels   = document.querySelectorAll<HTMLElement>('.panel');

    function activate(targetId: string) {
        panels.forEach(panel => {
            panel.hidden = `#${panel.id}` !== targetId;
        });
        navLinks.forEach(link => {
            const isActive = link.getAttribute('href') === targetId;
            link.classList.toggle('is-active', isActive);
            if (isActive) link.setAttribute('aria-current', 'page');
            else link.removeAttribute('aria-current');
        });
    }

    navLinks.forEach(link => {
        link.addEventListener('click', (event) => {
            event.preventDefault();
            const target = link.getAttribute('href');
            if (target) activate(target);
        });
    });

    const initial = document.querySelector<HTMLAnchorElement>('.sidebar-nav a.is-active') ?? navLinks[0];
    if (initial) activate(initial.getAttribute('href')!);

    const logoutBtn = document.querySelector<HTMLButtonElement>('#logout-btn');
    logoutBtn?.addEventListener('click', async () => {
        logoutBtn.disabled = true;
        try {
            const res = await fetch('/api/logout', { method: 'POST' });
            if (res.ok) {
                window.location.href = '/login';
                return;
            }
            logoutBtn.disabled = false;
        } catch {
            logoutBtn.disabled = false;
        }
    });

    const modal     = document.querySelector<HTMLDialogElement>('#new-user-modal');
    const openBtn   = document.querySelector<HTMLButtonElement>('#open-new-user');
    const closeBtn  = document.querySelector<HTMLButtonElement>('#nu-close');
    const cancelBtn = document.querySelector<HTMLButtonElement>('#nu-cancel');
    const fileInput = document.querySelector<HTMLInputElement>('#nu-avatar');
    const preview   = document.querySelector<HTMLSpanElement>('#nu-avatar-preview');
    const newUserForm = document.querySelector<HTMLFormElement>('#new-user-form');

    openBtn?.addEventListener('click', () => openCreate());
    closeBtn?.addEventListener('click', () => modal?.close());
    cancelBtn?.addEventListener('click', () => modal?.close());

    modal?.addEventListener('click', (event) => {
        if (event.target === modal) modal.close();
    });

    let previewUrl: string | null = null;
    fileInput?.addEventListener('change', () => {
        const file = fileInput.files?.[0];
        if (!file || !preview) return;
        if (previewUrl) URL.revokeObjectURL(previewUrl);
        previewUrl = URL.createObjectURL(file);
        preview.style.backgroundImage = `url(${previewUrl})`;
        preview.style.backgroundSize = 'cover';
        preview.style.backgroundPosition = 'center';
    });

    const nameInput     = document.querySelector<HTMLInputElement>('#nu-name');
    const emailInput    = document.querySelector<HTMLInputElement>('#nu-email');
    const passwordInput = document.querySelector<HTMLInputElement>('#nu-password');
    const nameError     = document.querySelector<HTMLParagraphElement>('#nu-name-error');
    const emailError    = document.querySelector<HTMLParagraphElement>('#nu-email-error');
    const passwordError = document.querySelector<HTMLParagraphElement>('#nu-password-error');
    const nuFormError   = document.querySelector<HTMLParagraphElement>('#nu-form-error');
    const submitBtn     = newUserForm?.querySelector<HTMLButtonElement>('.btn-primary');
    const phoneInput    = document.querySelector<HTMLInputElement>('#nu-phone');
    const roleSelect    = document.querySelector<HTMLSelectElement>('#nu-role');
    const statusField   = document.querySelector<HTMLDivElement>('#nu-status-field');
    const statusSelect  = document.querySelector<HTMLSelectElement>('#nu-status');
    const modalTitle    = document.querySelector<HTMLElement>('#nu-title');

    let editingUserId: string | null = null;

    function resetUserForm() {
        newUserForm?.reset();
        setFieldError(nameError, nameInput, '');
        setFieldError(emailError, emailInput, '');
        setFieldError(passwordError, passwordInput, '');
        if (nuFormError) nuFormError.textContent = '';
        if (previewUrl) { URL.revokeObjectURL(previewUrl); previewUrl = null; }
        if (preview) preview.style.backgroundImage = '';
    }

    function showStatusField(show: boolean) {
        if (statusField) statusField.hidden = !show;
        if (statusSelect) statusSelect.disabled = !show;
    }

    function openCreate() {
        editingUserId = null;
        resetUserForm();
        showStatusField(false);
        if (modalTitle) modalTitle.textContent = 'Nuevo usuario';
        if (passwordInput) {
            passwordInput.required = true;
            passwordInput.placeholder = 'Mínimo 8 caracteres';
        }
        if (submitBtn) submitBtn.textContent = 'Crear';
        modal?.showModal();
    }

    function openEdit(btn: HTMLButtonElement) {
        editingUserId = btn.dataset.editUser ?? null;
        resetUserForm();
        if (modalTitle) modalTitle.textContent = 'Editar usuario';
        if (nameInput)  nameInput.value  = btn.dataset.name  ?? '';
        if (emailInput) emailInput.value = btn.dataset.email ?? '';
        if (phoneInput) phoneInput.value = btn.dataset.phone ?? '';
        if (roleSelect) roleSelect.value = btn.dataset.role  ?? 'agent';
        
        const isSelf = btn.dataset.self === 'true';
        showStatusField(!isSelf);
        if (statusSelect) statusSelect.value = btn.dataset.active ?? 'true';
        if (passwordInput) {
            passwordInput.required = false;
            passwordInput.placeholder = 'Dejar en blanco para no cambiarla';
        }
        const avatar = btn.dataset.avatar;
        if (avatar && preview) {
            preview.style.backgroundImage = `url(${avatar})`;
            preview.style.backgroundSize = 'cover';
            preview.style.backgroundPosition = 'center';
        }
        if (submitBtn) submitBtn.textContent = 'Guardar';
        modal?.showModal();
    }

    document.querySelectorAll<HTMLButtonElement>('[data-edit-user]').forEach(btn => {
        btn.addEventListener('click', () => openEdit(btn));
    });

    const emailRe    = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const passwordRe = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).{8,}$/;

    const apiErrors: Record<string, string> = {
        'Email already in use': 'Ya existe un usuario con ese correo.',
        'Weak password':        'La contraseña no cumple los requisitos.',
        'Invalid email format': 'El correo no tiene un formato válido.',
        'Avatar must be an image': 'El archivo debe ser una imagen.',
        'Avatar exceeds 2 MB':  'La imagen supera los 2 MB.',
        'Could not upload avatar': 'No se pudo subir la imagen. Inténtalo de nuevo.',
    };

    function setFieldError(el: HTMLParagraphElement | null, input: HTMLInputElement | null, msg: string) {
        if (el) el.textContent = msg;
        if (input) input.setAttribute('aria-invalid', msg ? 'true' : 'false');
    }

    newUserForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!nameInput || !emailInput || !passwordInput || !submitBtn) return;

        if (nuFormError) nuFormError.textContent = '';

        const name     = nameInput.value.trim();
        const email    = emailInput.value.trim();
        const password = passwordInput.value;
        let valid = true;

        if (!name) {
            setFieldError(nameError, nameInput, 'Introduce el nombre completo.');
            valid = false;
        } else setFieldError(nameError, nameInput, '');

        if (!email) {
            setFieldError(emailError, emailInput, 'Introduce el correo.');
            valid = false;
        } else if (!emailRe.test(email)) {
            setFieldError(emailError, emailInput, 'El correo no tiene un formato válido.');
            valid = false;
        } else setFieldError(emailError, emailInput, '');

        if (!editingUserId && !password) {
            setFieldError(passwordError, passwordInput, 'Introduce una contraseña.');
            valid = false;
        } else if (password && !passwordRe.test(password)) {
            setFieldError(passwordError, passwordInput, 'Mínimo 8 caracteres, con mayúscula, minúscula y número.');
            valid = false;
        } else setFieldError(passwordError, passwordInput, '');

        if (!valid) return;

        const isEdit = editingUserId !== null;
        submitBtn.disabled = true;
        submitBtn.textContent = isEdit ? 'Guardando…' : 'Creando…';

        try {
            const formData = new FormData(newUserForm);
            if (isEdit && !password) formData.delete('password');

            const res = await fetch(
                isEdit ? `/api/users/${editingUserId}` : '/api/users',
                { method: isEdit ? 'PATCH' : 'POST', body: formData },
            );

            if (res.ok) {
                window.location.reload();
                return;
            }

            const data = await res.json().catch(() => ({})) as { error?: string };
            if (nuFormError) {
                nuFormError.textContent = (data.error && apiErrors[data.error])
                    ?? (isEdit ? 'No se pudo guardar. Inténtalo de nuevo.' : 'No se pudo crear el usuario. Inténtalo de nuevo.');
            }
        } catch {
            if (nuFormError) nuFormError.textContent = 'Error de conexión. Inténtalo de nuevo.';
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = isEdit ? 'Guardar' : 'Crear';
        }
    });

    const usersCount = document.querySelector<HTMLElement>('.sidebar-nav a[href="#usuarios"] em');
    const deleteErrors: Record<string, string> = {
        'User has assigned properties': 'No se puede eliminar: el usuario tiene propiedades asignadas.',
        'User not found':               'El usuario ya no existe.',
    };

    document.querySelectorAll<HTMLButtonElement>('[data-delete-user]').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id   = btn.dataset.deleteUser;
            const name = btn.dataset.userName ?? 'este usuario';
            if (!id) return;

            const ok = await askConfirm({
                title:        'Eliminar usuario',
                message:      `¿Seguro que quieres eliminar a ${name}? Esta acción no se puede deshacer.`,
                confirmLabel: 'Eliminar',
            });
            if (!ok) return;

            btn.disabled = true;
            try {
                const res = await fetch(`/api/users/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    btn.closest('.user-row')?.remove();
                    if (usersCount) usersCount.textContent = String(Math.max(0, Number(usersCount.textContent) - 1));
                    return;
                }
                const data = await res.json().catch(() => ({})) as { error?: string };
                alert((data.error && deleteErrors[data.error]) ?? 'No se pudo eliminar el usuario.');
                btn.disabled = false;
            } catch {
                alert('Error de conexión. Inténtalo de nuevo.');
                btn.disabled = false;
            }
        });
    });

    // ── Modal: create / edit zone ───────────────────────────
    const zoneModal      = document.querySelector<HTMLDialogElement>('#new-zone-modal');
    const openZoneBtn    = document.querySelector<HTMLButtonElement>('#open-new-zone');
    const zoneCloseBtn   = document.querySelector<HTMLButtonElement>('#nz-close');
    const zoneCancelBtn  = document.querySelector<HTMLButtonElement>('#nz-cancel');
    const zoneForm       = document.querySelector<HTMLFormElement>('#new-zone-form');
    const zoneTitle      = document.querySelector<HTMLElement>('#nz-title');
    const zoneNameInput  = document.querySelector<HTMLInputElement>('#nz-name');
    const zoneNameError  = document.querySelector<HTMLParagraphElement>('#nz-name-error');
    const zoneFormError  = document.querySelector<HTMLParagraphElement>('#nz-form-error');
    const zoneCountrySel = document.querySelector<HTMLSelectElement>('#nz-country');
    const zoneSlugInput  = document.querySelector<HTMLInputElement>('#nz-slug');
    const zoneDescInput  = document.querySelector<HTMLTextAreaElement>('#nz-description');
    const zoneTagsInput  = document.querySelector<HTMLInputElement>('#nz-tags');
    const zoneOrderInput = document.querySelector<HTMLInputElement>('#nz-order');
    const zoneStatusField  = document.querySelector<HTMLDivElement>('#nz-status-field');
    const zoneStatusSelect = document.querySelector<HTMLSelectElement>('#nz-status');
    const zoneImageInput   = document.querySelector<HTMLInputElement>('#nz-image');
    const zoneImagePreview = document.querySelector<HTMLSpanElement>('#nz-image-preview');
    const zoneSubmitBtn    = zoneForm?.querySelector<HTMLButtonElement>('.btn-primary');

    const zoneApiErrors: Record<string, string> = {
        'Country not found':        'El país seleccionado no existe.',
        'A zone with that slug already exists': 'Ya existe una zona con ese slug.',
        'Image must be an image file': 'El archivo debe ser una imagen.',
        'Image exceeds 5 MB':       'La imagen supera los 5 MB.',
        'Could not upload image':   'No se pudo subir la imagen. Inténtalo de nuevo.',
    };

    let editingZoneId: string | null = null;
    let zonePreviewUrl: string | null = null;

    function resetZoneForm() {
        zoneForm?.reset();
        if (zoneNameError) zoneNameError.textContent = '';
        zoneNameInput?.setAttribute('aria-invalid', 'false');
        if (zoneFormError) zoneFormError.textContent = '';
        if (zonePreviewUrl) { URL.revokeObjectURL(zonePreviewUrl); zonePreviewUrl = null; }
        if (zoneImagePreview) zoneImagePreview.style.backgroundImage = '';
    }

    function showZoneStatus(show: boolean) {
        if (zoneStatusField) zoneStatusField.hidden = !show;
        if (zoneStatusSelect) zoneStatusSelect.disabled = !show;
    }

    function openCreateZone() {
        editingZoneId = null;
        resetZoneForm();
        showZoneStatus(false);
        if (zoneTitle) zoneTitle.textContent = 'Nueva zona';
        if (zoneSubmitBtn) zoneSubmitBtn.textContent = 'Crear';
        zoneModal?.showModal();
    }

    function openEditZone(btn: HTMLButtonElement) {
        editingZoneId = btn.dataset.editZone ?? null;
        resetZoneForm();
        showZoneStatus(true);
        if (zoneTitle) zoneTitle.textContent = 'Editar zona';
        if (zoneNameInput)   zoneNameInput.value   = btn.dataset.name        ?? '';
        if (zoneCountrySel)  zoneCountrySel.value   = btn.dataset.country     ?? '';
        if (zoneSlugInput)   zoneSlugInput.value    = btn.dataset.slug        ?? '';
        if (zoneDescInput)   zoneDescInput.value    = btn.dataset.description ?? '';
        if (zoneTagsInput)   zoneTagsInput.value    = btn.dataset.tags        ?? '';
        if (zoneOrderInput)  zoneOrderInput.value   = btn.dataset.order       ?? '0';
        if (zoneStatusSelect) zoneStatusSelect.value = btn.dataset.active     ?? 'true';
        const image = btn.dataset.image;
        if (image && zoneImagePreview) {
            zoneImagePreview.style.backgroundImage = `url(${image})`;
            zoneImagePreview.style.backgroundSize = 'cover';
            zoneImagePreview.style.backgroundPosition = 'center';
        }
        if (zoneSubmitBtn) zoneSubmitBtn.textContent = 'Guardar';
        zoneModal?.showModal();
    }

    openZoneBtn?.addEventListener('click', () => openCreateZone());
    zoneCloseBtn?.addEventListener('click', () => zoneModal?.close());
    zoneCancelBtn?.addEventListener('click', () => zoneModal?.close());
    zoneModal?.addEventListener('click', (event) => {
        if (event.target === zoneModal) zoneModal.close();
    });

    document.querySelectorAll<HTMLButtonElement>('[data-edit-zone]').forEach(btn => {
        btn.addEventListener('click', () => openEditZone(btn));
    });

    zoneImageInput?.addEventListener('change', () => {
        const file = zoneImageInput.files?.[0];
        if (!file || !zoneImagePreview) return;
        if (zonePreviewUrl) URL.revokeObjectURL(zonePreviewUrl);
        zonePreviewUrl = URL.createObjectURL(file);
        zoneImagePreview.style.backgroundImage = `url(${zonePreviewUrl})`;
        zoneImagePreview.style.backgroundSize = 'cover';
        zoneImagePreview.style.backgroundPosition = 'center';
    });

    zoneForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!zoneNameInput || !zoneSubmitBtn) return;

        if (zoneFormError) zoneFormError.textContent = '';

        const name = zoneNameInput.value.trim();
        if (!name) {
            if (zoneNameError) zoneNameError.textContent = 'Introduce el nombre de la zona.';
            zoneNameInput.setAttribute('aria-invalid', 'true');
            return;
        }
        if (zoneNameError) zoneNameError.textContent = '';
        zoneNameInput.setAttribute('aria-invalid', 'false');

        const isEdit = editingZoneId !== null;
        zoneSubmitBtn.disabled = true;
        zoneSubmitBtn.textContent = isEdit ? 'Guardando…' : 'Creando…';

        try {
            const res = await fetch(
                isEdit ? `/api/zones/${editingZoneId}` : '/api/zones',
                { method: isEdit ? 'PATCH' : 'POST', body: new FormData(zoneForm) },
            );
            if (res.ok) {
                window.location.reload();
                return;
            }
            const data = await res.json().catch(() => ({})) as { error?: string };
            if (zoneFormError) {
                zoneFormError.textContent = (data.error && zoneApiErrors[data.error])
                    ?? (isEdit ? 'No se pudo guardar la zona. Inténtalo de nuevo.' : 'No se pudo crear la zona. Inténtalo de nuevo.');
            }
        } catch {
            if (zoneFormError) zoneFormError.textContent = 'Error de conexión. Inténtalo de nuevo.';
        } finally {
            zoneSubmitBtn.disabled = false;
            zoneSubmitBtn.textContent = isEdit ? 'Guardar' : 'Crear';
        }
    });

    // ── Delete zone ──────────────────────────────────────────
    const zonesCount = document.querySelector<HTMLElement>('.sidebar-nav a[href="#zonas"] em');
    const zoneDeleteErrors: Record<string, string> = {
        'Zone has properties': 'No se puede eliminar: la zona tiene propiedades asignadas.',
        'Zone not found':      'La zona ya no existe.',
    };

    document.querySelectorAll<HTMLButtonElement>('[data-delete-zone]').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id   = btn.dataset.deleteZone;
            const name = btn.dataset.zoneName ?? 'esta zona';
            if (!id) return;

            const ok = await askConfirm({
                title:        'Eliminar zona',
                message:      `¿Seguro que quieres eliminar ${name}? Esta acción no se puede deshacer.`,
                confirmLabel: 'Eliminar',
            });
            if (!ok) return;

            btn.disabled = true;
            try {
                const res = await fetch(`/api/zones/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    btn.closest('.user-row')?.remove();
                    if (zonesCount) zonesCount.textContent = String(Math.max(0, Number(zonesCount.textContent) - 1));
                    return;
                }
                const data = await res.json().catch(() => ({})) as { error?: string };
                alert((data.error && zoneDeleteErrors[data.error]) ?? 'No se pudo eliminar la zona.');
                btn.disabled = false;
            } catch {
                alert('Error de conexión. Inténtalo de nuevo.');
                btn.disabled = false;
            }
        });
    });

    // ── Modal: new property ──────────────────────────────────
    const propModal     = document.querySelector<HTMLDialogElement>('#new-property-modal');
    const openPropBtn   = document.querySelector<HTMLButtonElement>('#open-new-property');
    const propCloseBtn  = document.querySelector<HTMLButtonElement>('#np-close');
    const propCancelBtn = document.querySelector<HTMLButtonElement>('#np-cancel');
    const propForm      = document.querySelector<HTMLFormElement>('#new-property-form');
    const propModalTitle = document.querySelector<HTMLElement>('#np-title');
    const propTitleInput = document.querySelector<HTMLInputElement>('#np-title');
    const propZoneSelect = document.querySelector<HTMLSelectElement>('#np-zone');
    const propAgentSelect = document.querySelector<HTMLSelectElement>('#np-agent');
    const propPriceInput = document.querySelector<HTMLInputElement>('#np-price');
    const propBedsInput  = document.querySelector<HTMLInputElement>('#np-beds');
    const propBathsInput = document.querySelector<HTMLInputElement>('#np-baths');
    const propBuiltInput = document.querySelector<HTMLInputElement>('#np-built');
    const propTerrainInput = document.querySelector<HTMLInputElement>('#np-terrain');
    const propTagSelect    = document.querySelector<HTMLSelectElement>('#np-tag');
    const propStatusSelect = document.querySelector<HTMLSelectElement>('#np-status');
    const propDescInput     = document.querySelector<HTMLTextAreaElement>('#np-description');
    const propFeaturesInput = document.querySelector<HTMLInputElement>('#np-features');
    const propDistancesInput = document.querySelector<HTMLTextAreaElement>('#np-distances');
    const propLatInput  = document.querySelector<HTMLInputElement>('#np-lat');
    const propLngInput  = document.querySelector<HTMLInputElement>('#np-lng');
    const propFeaturedInput = document.querySelector<HTMLInputElement>('#np-featured');
    const propTitleError = document.querySelector<HTMLParagraphElement>('#np-title-error');
    const propPriceError = document.querySelector<HTMLParagraphElement>('#np-price-error');
    const propFormError  = document.querySelector<HTMLParagraphElement>('#np-form-error');
    const propSubmitBtn  = propForm?.querySelector<HTMLButtonElement>('.btn-primary');

    let editingPropertyId: string | null = null;

    const propApiErrors: Record<string, string> = {
        'Zone not found': 'La zona seleccionada no existe.',
        'A property can have at most 10 photos': 'Una propiedad puede tener como máximo 10 fotos.',
        'All photos must be images': 'Todos los archivos deben ser imágenes.',
        'Each photo must be under 5 MB': 'Cada foto debe pesar menos de 5 MB.',
        'Could not upload photos': 'No se pudieron subir las fotos. Inténtalo de nuevo.',
    };

    // ── In-modal photo manager (in memory until the property is created) ──
    const PROP_MAX_PHOTOS = 10;
    const propPhotosInput = document.querySelector<HTMLInputElement>('#np-photos');
    const propPhotosLabel = document.querySelector<HTMLLabelElement>('#np-photos-label');
    const propPhotoList   = document.querySelector<HTMLUListElement>('#np-photo-list');

    // `file` for newly added photos, `existingId` for ones already stored.
    interface PropPhoto { file?: File; url: string; caption: string; existingId?: number; }
    let propPhotos: PropPhoto[] = [];
    let draggedPhoto: HTMLLIElement | null = null;

    function renderPropPhotos() {
        if (!propPhotoList) return;
        propPhotoList.innerHTML = '';
        propPhotos.forEach((photo, i) => {
            const li = document.createElement('li');
            li.className = 'photo-row';
            li.draggable = false;
            li.dataset.index = String(i);

            // Drag handle (grip): dragging is only enabled while grabbing it.
            const handle = document.createElement('span');
            handle.className = 'photo-handle';
            handle.setAttribute('aria-hidden', 'true');
            handle.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="6" r="1.6"/><circle cx="15" cy="6" r="1.6"/><circle cx="9" cy="12" r="1.6"/><circle cx="15" cy="12" r="1.6"/><circle cx="9" cy="18" r="1.6"/><circle cx="15" cy="18" r="1.6"/></svg>';
            handle.addEventListener('mousedown', () => { li.draggable = true; });

            const thumb = document.createElement('span');
            thumb.className = 'photo-thumb';
            thumb.style.backgroundImage = `url(${photo.url})`;
            if (i === 0) thumb.dataset.cover = 'true';

            const caption = document.createElement('input');
            caption.type = 'text';
            caption.className = 'photo-caption-input';
            caption.placeholder = 'Pie de foto (opcional)';
            caption.value = photo.caption;
            caption.addEventListener('input', () => { photo.caption = caption.value; });

            const remove = document.createElement('button');
            remove.type = 'button';
            remove.className = 'photo-remove-btn';
            remove.setAttribute('aria-label', 'Quitar foto');
            remove.textContent = '×';
            remove.addEventListener('click', () => {
                URL.revokeObjectURL(photo.url);
                propPhotos.splice(i, 1);
                renderPropPhotos();
            });

            li.append(handle, thumb, caption, remove);
            propPhotoList.appendChild(li);
        });
    }

    function clearPropPhotos() {
        propPhotos.forEach(p => URL.revokeObjectURL(p.url));
        propPhotos = [];
        renderPropPhotos();
    }

    propPhotosInput?.addEventListener('change', () => {
        const incoming = Array.from(propPhotosInput.files ?? []);
        for (const file of incoming) {
            if (propPhotos.length >= PROP_MAX_PHOTOS) break;
            propPhotos.push({ file, url: URL.createObjectURL(file), caption: '' });
        }
        propPhotosInput.value = '';
        renderPropPhotos();
    });

    // Drag & drop reordering (the first photo becomes the cover).
    function getPhotoAfter(y: number): HTMLElement | null {
        if (!propPhotoList) return null;
        const items = [...propPhotoList.querySelectorAll<HTMLElement>('.photo-row:not(.dragging)')];
        let closest: { offset: number; element: HTMLElement | null } = { offset: -Infinity, element: null };
        for (const child of items) {
            const box = child.getBoundingClientRect();
            const offset = y - box.top - box.height / 2;
            if (offset < 0 && offset > closest.offset) closest = { offset, element: child };
        }
        return closest.element;
    }

    propPhotoList?.addEventListener('dragstart', (event) => {
        const li = (event.target as HTMLElement).closest('.photo-row') as HTMLLIElement | null;
        if (!li) return;
        draggedPhoto = li;
        li.classList.add('dragging');
    });

    propPhotoList?.addEventListener('dragover', (event) => {
        event.preventDefault();
        if (!propPhotoList || !draggedPhoto) return;
        const after = getPhotoAfter(event.clientY);
        if (after == null) propPhotoList.appendChild(draggedPhoto);
        else propPhotoList.insertBefore(draggedPhoto, after);
    });

    propPhotoList?.addEventListener('dragend', () => {
        if (!draggedPhoto) return;
        draggedPhoto.classList.remove('dragging');
        draggedPhoto.draggable = false;
        draggedPhoto = null;
        // Reorder the state array to match the new DOM order.
        const order = [...(propPhotoList?.querySelectorAll<HTMLLIElement>('.photo-row') ?? [])]
            .map(li => Number(li.dataset.index));
        propPhotos = order.map(i => propPhotos[i]);
        renderPropPhotos();
    });

    function resetPropForm() {
        propForm?.reset();
        clearPropPhotos();
        if (propPhotosLabel) propPhotosLabel.textContent = 'Subir fotos';
        [propTitleError, propPriceError, propFormError].forEach(el => { if (el) el.textContent = ''; });
        [propTitleInput, propZoneSelect, propPriceInput, propBedsInput, propBathsInput, propBuiltInput]
            .forEach(el => el?.setAttribute('aria-invalid', 'false'));
    }

    function openCreateProperty() {
        editingPropertyId = null;
        resetPropForm();
        if (propModalTitle) propModalTitle.textContent = 'Nueva propiedad';
        if (propSubmitBtn) propSubmitBtn.textContent = 'Crear';
        propModal?.showModal();
    }

    async function openEditProperty(id: string) {
        editingPropertyId = id;
        resetPropForm();
        if (propModalTitle) propModalTitle.textContent = 'Editar propiedad';
        if (propSubmitBtn) propSubmitBtn.textContent = 'Guardar';
        propModal?.showModal();

        try {
            const res = await fetch(`/api/properties/${id}`);
            if (!res.ok) throw new Error('fetch failed');
            const { property, images } = await res.json() as {
                property: Record<string, any>;
                images: { id: number; url: string; caption: string | null }[];
            };

            if (propTitleInput)  propTitleInput.value  = property.title ?? '';
            if (propZoneSelect)  propZoneSelect.value  = String(property.zone_id ?? '');
            if (propAgentSelect) propAgentSelect.value = String(property.agent_id ?? '');
            if (propPriceInput)  propPriceInput.value  = String(property.price ?? '');
            if (propBedsInput)   propBedsInput.value   = String(property.n_beds ?? '');
            if (propBathsInput)  propBathsInput.value  = String(property.n_baths ?? '');
            if (propBuiltInput)  propBuiltInput.value  = String(property.m_built ?? '');
            if (propTerrainInput) propTerrainInput.value = property.terrain_space ?? '';
            if (propTagSelect)    propTagSelect.value    = property.tag ?? 'for_sale';
            if (propStatusSelect) propStatusSelect.value = property.status ?? 'draft';
            if (propDescInput)    propDescInput.value    = property.description ?? '';
            if (propFeaturesInput) propFeaturesInput.value = (property.features ?? []).join(', ');
            if (propDistancesInput) propDistancesInput.value =
                (property.distances ?? []).map((d: any) => `${d.value} ${d.unit} ${d.label}`).join('\n');
            if (propLatInput) propLatInput.value = property.latitude ?? '';
            if (propLngInput) propLngInput.value = property.longitude ?? '';
            if (propFeaturedInput) propFeaturedInput.checked = Boolean(property.is_featured);

            propPhotos = images.map(img => ({
                existingId: img.id,
                url:        img.url,
                caption:    img.caption ?? '',
            }));
            renderPropPhotos();
        } catch {
            if (propFormError) propFormError.textContent = 'No se pudieron cargar los datos de la propiedad.';
        }
    }

    openPropBtn?.addEventListener('click', () => openCreateProperty());
    document.querySelectorAll<HTMLButtonElement>('[data-edit-property]').forEach(btn => {
        btn.addEventListener('click', () => openEditProperty(btn.dataset.editProperty!));
    });
    propCloseBtn?.addEventListener('click', () => propModal?.close());
    propCancelBtn?.addEventListener('click', () => propModal?.close());
    propModal?.addEventListener('click', (event) => {
        if (event.target === propModal) propModal.close();
    });

    // Marks a numeric field invalid when empty or below its minimum.
    function validateNumber(input: HTMLInputElement | null, min: number): boolean {
        if (!input) return true;
        const ok = input.value !== '' && Number(input.value) >= min;
        input.setAttribute('aria-invalid', ok ? 'false' : 'true');
        return ok;
    }

    propForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        console.log(propTitleInput);
        console.log(propPriceInput);
        console.log(propSubmitBtn);
        

        if (!propTitleInput || !propPriceInput || !propSubmitBtn) return;

        if (propFormError) propFormError.textContent = '';
        let valid = true;

        if (!propTitleInput.value.trim()) {
            if (propTitleError) propTitleError.textContent = 'Introduce el título.';
            propTitleInput.setAttribute('aria-invalid', 'true');
            valid = false;
        } else { if (propTitleError) propTitleError.textContent = ''; propTitleInput.setAttribute('aria-invalid', 'false'); }

        // Zone: there must be a selectable option.
        if (!propZoneSelect?.value) {
            propZoneSelect?.setAttribute('aria-invalid', 'true');
            if (propFormError) propFormError.textContent = 'Selecciona una zona (crea una antes si no hay ninguna).';
            valid = false;
        } else { propZoneSelect.setAttribute('aria-invalid', 'false'); }

        if (!propPriceInput.value || Number(propPriceInput.value) <= 0) {
            if (propPriceError) propPriceError.textContent = 'Introduce un precio válido.';
            propPriceInput.setAttribute('aria-invalid', 'true');
            valid = false;
        } else { if (propPriceError) propPriceError.textContent = ''; propPriceInput.setAttribute('aria-invalid', 'false'); }

        // Required integers (≥ 0 for rooms/baths, ≥ 1 for built area).
        const numbersOk = [
            validateNumber(propBedsInput, 0),
            validateNumber(propBathsInput, 0),
            validateNumber(propBuiltInput, 1),
        ].every(Boolean);
        if (!numbersOk) {
            if (propFormError && !propFormError.textContent) {
                propFormError.textContent = 'Revisa habitaciones, baños y metros construidos.';
            }
            valid = false;
        }

        if (!valid) return;

        const isEdit = editingPropertyId !== null;
        propSubmitBtn.disabled = true;
        propSubmitBtn.textContent = isEdit ? 'Guardando…' : 'Creando…';

        try {
            const formData = new FormData(propForm);

            if (isEdit) {
                // Send the desired gallery order: existing images by id, new ones by file index.
                const order: { existingId?: number; newIndex?: number; caption: string }[] = [];
                let newIndex = 0;
                propPhotos.forEach(photo => {
                    if (photo.existingId != null) {
                        order.push({ existingId: photo.existingId, caption: photo.caption });
                    } else if (photo.file) {
                        formData.append('photos', photo.file);
                        order.push({ newIndex: newIndex++, caption: photo.caption });
                    }
                });
                formData.append('images_order', JSON.stringify(order));
            } else {
                // Create: photos and captions as parallel arrays in display order.
                propPhotos.forEach(photo => {
                    if (photo.file) {
                        formData.append('photos', photo.file);
                        formData.append('captions', photo.caption);
                    }
                });
            }

            const res = await fetch(
                isEdit ? `/api/properties/${editingPropertyId}` : '/api/properties',
                { method: isEdit ? 'PATCH' : 'POST', body: formData },
            );
            if (res.ok) {
                window.location.reload();
                return;
            }
            const data = await res.json().catch(() => ({})) as { error?: string };
            if (propFormError) {
                propFormError.textContent = (data.error && propApiErrors[data.error])
                    ?? (isEdit ? 'No se pudo guardar la propiedad. Inténtalo de nuevo.' : 'No se pudo crear la propiedad. Inténtalo de nuevo.');
            }
        } catch {
            if (propFormError) propFormError.textContent = 'Error de conexión. Inténtalo de nuevo.';
        } finally {
            propSubmitBtn.disabled = false;
            propSubmitBtn.textContent = isEdit ? 'Guardar' : 'Crear';
        }
    });

    // ── Delete property ──────────────────────────────────────
    const propsCount = document.querySelector<HTMLElement>('.sidebar-nav a[href="#propiedades"] em');

    document.querySelectorAll<HTMLButtonElement>('[data-delete-property]').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id    = btn.dataset.deleteProperty;
            const title = btn.dataset.title ?? 'esta propiedad';
            if (!id) return;

            const ok = await askConfirm({
                title:        'Eliminar propiedad',
                message:      `¿Seguro que quieres eliminar "${title}"? Se borrarán también sus fotos. Esta acción no se puede deshacer.`,
                confirmLabel: 'Eliminar',
            });
            if (!ok) return;

            btn.disabled = true;
            try {
                const res = await fetch(`/api/properties/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    btn.closest('.user-row')?.remove();
                    if (propsCount) propsCount.textContent = String(Math.max(0, Number(propsCount.textContent) - 1));
                    return;
                }
                alert('No se pudo eliminar la propiedad.');
                btn.disabled = false;
            } catch {
                alert('Error de conexión. Inténtalo de nuevo.');
                btn.disabled = false;
            }
        });
    });

    // ── Visit requests: change status / delete ──
    const visitsCount = document.querySelector<HTMLElement>('.sidebar-nav a[href="#solicitudes"] em');
    const visitStatusLabels: Record<string, string> = {
        pending: 'Pendiente', contacted: 'Contactado', closed: 'Cerrado',
    };

    document.querySelectorAll<HTMLSelectElement>('[data-visit-status]').forEach(select => {
        let previous = select.value;
        select.addEventListener('change', async () => {
            const id = select.dataset.visitStatus;
            const status = select.value;
            if (!id) return;

            select.disabled = true;
            try {
                const res = await fetch(`/api/visit-requests/${id}`, {
                    method:  'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ status }),
                });
                if (res.ok) {
                    previous = status;
                    const badge = select.closest('.user-row')?.querySelector<HTMLElement>('[data-visit-badge]');
                    if (badge) {
                        badge.className = `badge badge--visit-${status}`;
                        badge.textContent = visitStatusLabels[status] ?? status;
                    }
                } else {
                    select.value = previous;
                    alert('No se pudo actualizar el estado.');
                }
            } catch {
                select.value = previous;
                alert('Error de conexión. Inténtalo de nuevo.');
            } finally {
                select.disabled = false;
            }
        });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-delete-visit]').forEach(btn => {
        btn.addEventListener('click', async () => {
            const id   = btn.dataset.deleteVisit;
            const name = btn.dataset.visitName ?? 'esta solicitud';
            if (!id) return;

            const ok = await askConfirm({
                title:        'Eliminar solicitud',
                message:      `¿Seguro que quieres eliminar la solicitud de "${name}"? Esta acción no se puede deshacer.`,
                confirmLabel: 'Eliminar',
            });
            if (!ok) return;

            btn.disabled = true;
            try {
                const res = await fetch(`/api/visit-requests/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    btn.closest('.user-row')?.remove();
                    if (visitsCount) visitsCount.textContent = String(Math.max(0, Number(visitsCount.textContent) - 1));
                    return;
                }
                alert('No se pudo eliminar la solicitud.');
                btn.disabled = false;
            } catch {
                alert('Error de conexión. Inténtalo de nuevo.');
                btn.disabled = false;
            }
        });
    });

</script>

