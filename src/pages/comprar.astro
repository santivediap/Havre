---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import SEO from "../components/SEO.astro"
import "../styles/global.css"
import "leaflet/dist/leaflet.css"
import ArrowRight from "../components/icons/ArrowRight.astro"
import Search from "../components/icons/Search.astro"
import { searchProperties, type PropertyFilters } from "../services/properties"
import { getZones } from "../services/zones"

// ── Read the filter state from the URL (shareable, server-side filtered) ──
const params = Astro.url.searchParams
const toInt = (v: string | null) => {
    const n = parseInt(v ?? '', 10)
    return Number.isFinite(n) ? n : undefined
}

const selZone    = params.get('zona')  ?? ''
const selMin     = toInt(params.get('min'))
const selMax     = toInt(params.get('max'))
const selTerreno = toInt(params.get('terreno'))
const selHabs    = toInt(params.get('habs'))
const sortOptions = ['featured', 'price-asc', 'price-desc', 'newest'] as const
const selOrder    = (sortOptions as readonly string[]).includes(params.get('order') ?? '')
    ? params.get('order') as PropertyFilters['sort']
    : 'featured'

const filters: PropertyFilters = {
    zone:     selZone || undefined,
    priceMin: selMin,
    priceMax: selMax,
    builtMin: selTerreno,
    bedsMin:  selHabs,
    sort:     selOrder,
}

const [propertyList, zoneList] = await Promise.all([
    searchProperties(filters, 40),
    getZones(),
])

const tagLabels: Record<string, string> = {
    for_sale: "EN VENTA", new: "NUEVO", reserved: "RESERVADO", sold: "VENDIDO",
}

const nf = new Intl.NumberFormat('es-ES')

// ── Dynamic SEO: a zone-filtered view gets its own title/description ──
const activeZone = selZone ? zoneList.find(z => z.slug === selZone) : null
// A zone-only view is a worthwhile landing page; richer filter combos are noindex.
const noindex = [...params.keys()].some(k => k !== 'zona')
const pageTitle = activeZone
    ? `Casas rurales en venta en ${activeZone.name} | Havre`
    : "Comprar casa rural — Propiedades en venta | Havre"
const pageDescription = activeZone
    ? `Descubre casas de campo, masías y fincas en venta en ${activeZone.name}, ${activeZone.country}. Acompañamiento personal de principio a fin.`
    : "Explora más de 340 casas de campo, masías, fincas y cortijos en venta en Toscana, Provenza, Pirineos, Alentejo y Empordà."
const canonical = activeZone ? `/comprar?zona=${activeZone.slug}` : "/comprar"

// Lightweight points (only those with coordinates) for the Leaflet map.
const mapPoints = propertyList
    .filter(p => p.latitude != null && p.longitude != null)
    .map(p => ({
        id:    p.id,
        slug:  p.slug,
        title: p.title,
        price: p.price,
        image: p.image_url,
        lat:   Number(p.latitude),
        lng:   Number(p.longitude),
    }))

const zones = [
    { label: "Todas las zonas", value: "" },
    ...zoneList.map(z => ({ label: z.name, value: z.slug })),
]

const pricesMin = [
    { label: "€ mín.",       value: "min"     },
    { label: "€ 100.000",    value: "100000"  },
    { label: "€ 200.000",    value: "200000"  },
    { label: "€ 300.000",    value: "300000"  },
    { label: "€ 500.000",    value: "500000"  },
    { label: "€ 750.000",    value: "750000"  },
    { label: "€ 1.000.000",  value: "1000000" },
]

const pricesMax = [
    { label: "€ máx.",       value: "max"      },
    { label: "€ 300.000",    value: "300000"   },
    { label: "€ 500.000",    value: "500000"   },
    { label: "€ 750.000",    value: "750000"   },
    { label: "€ 1.000.000",  value: "1000000"  },
    { label: "€ 1.500.000",  value: "1500000"  },
    { label: "€ 2.000.000",  value: "2000000"  },
]
const surfaces = [
    { label: "Cualquiera", value: "any" },
    { label: "100 m²",     value: "100" },
    { label: "300 m²",     value: "300" },
    { label: "500 m²",     value: "500" }
]
const roomOpts = [
    { label: "Todas", value: ""  },
    { label: "1+",    value: "1" },
    { label: "2+",    value: "2" },
    { label: "3+",    value: "3" },
    { label: "4+",    value: "4" },
    { label: "5+",    value: "5" },
]
const sortOpts = [
    { label: "Destacados",             value: "featured"   },
    { label: "Precio: menor a mayor",  value: "price-asc"  },
    { label: "Precio: mayor a menor",  value: "price-desc" },
    { label: "Más recientes",          value: "newest"     },
]
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO
        title={pageTitle}
        description={pageDescription}
        canonical={canonical}
        noindex={noindex}
    />
</head>
<body>
    <Header/>

    <main>
        <form class="filters-bar" role="search" aria-label="Filtrar propiedades">
            <div class="filters-primary">
                <div class="filter-group">
                    <label for="filter-zone">ZONA</label>
                    <select id="filter-zone" name="zone">
                        { zones.map(z => <option value={z.value} selected={z.value === selZone}>{z.label}</option>) }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-price-min">DESDE</label>
                    <select id="filter-price-min" name="price-min">
                        { pricesMin.map(p => <option value={p.value} selected={p.value === String(selMin ?? 'min')}>{p.label}</option>) }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-price-max">HASTA</label>
                    <select id="filter-price-max" name="price-max">
                        { pricesMax.map(p => <option value={p.value} selected={p.value === String(selMax ?? 'max')}>{p.label}</option>) }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-surface">M² MÍN.</label>
                    <select id="filter-surface" name="surface">
                        { surfaces.map(s => <option value={s.value} selected={s.value === String(selTerreno ?? 'any')}>{s.label}</option>) }
                    </select>
                </div>

                <fieldset class="filter-group">
                    <label for="rooms">HAB.</label>
                    <div class="room-opts">
                        { roomOpts.map(opt => (
                            <label class="room-option">
                                <input type="radio" name="rooms" value={opt.value} checked={opt.value === String(selHabs ?? '')} />
                                <span>{opt.label}</span>
                            </label>
                        )) }
                    </div>
                </fieldset>

                <div class="filters-secondary">
                    <a href="/comprar" class="filters-clear">Limpiar filtros</a>
                    <div class="filter-group">
                        <label for="filter-sort">ORDEN</label>
                        <select id="filter-sort" name="sort">
                            { sortOpts.map(o => <option value={o.value} selected={o.value === selOrder}>{o.label}</option>) }
                        </select>
                    </div>
                    <button type="submit" class="filters-search"><Search/> Buscar</button>
                </div>
            </div>

        </form>

        <div class="content-layout">
            <section class="properties-panel" aria-label="Listado de propiedades">
                <div class="results-header">
                    <h1>
                        { activeZone ? `Propiedades en ${activeZone.name}` : "Propiedades en venta" }
                        <span class="results-count">{propertyList.length} {propertyList.length === 1 ? 'resultado' : 'resultados'}</span>
                    </h1>
                </div>

                <ul class="properties-grid" role="list">
                    { propertyList.map(property => (
                        <li>
                            <article class="property-card">
                                <a class="property-image" href={`/comprar/${property.slug}`} aria-label={property.title} style={property.image_url ? `--img: url(${property.image_url})` : undefined}>
                                    <p class="property-tag">{tagLabels[property.tag] ?? "EN VENTA"}</p>
                                </a>

                                <div class="property-info">
                                    <p class="property-location">{`${property.zone}, ${property.country}`}</p>
                                    <h2 class="property-title">{property.title}</h2>

                                    <ul class="property-specs" role="list">
                                        <li class="property-spec">{property.n_beds} hab.</li>
                                        <li class="property-spec">{property.n_baths} baños</li>
                                        <li class="property-spec">{property.m_built} m²</li>
                                        { property.terrain_space && (
                                            <li class="property-spec">{nf.format(Number(property.terrain_space))} ha</li>
                                        ) }
                                    </ul>

                                    <div class="property-footer">
                                        <p class="property-price">€ {nf.format(property.price)}</p>
                                        <a class="property-link" href={`/comprar/${property.slug}`}>Ver ficha <ArrowRight/></a>
                                    </div>
                                </div>
                            </article>
                        </li>
                    )) }
                </ul>

                { propertyList.length === 0 && (
                    <div class="no-results">
                        <p>No hay propiedades que coincidan con tu búsqueda.</p>
                        <a href="/comprar" class="no-results-reset">Ver todas las propiedades</a>
                    </div>
                ) }
            </section>

            <aside class="map-panel" aria-label="Mapa de propiedades">
                <div id="property-map"></div>
            </aside>
        </div>
    </main>

    <script type="application/json" id="map-data" set:html={JSON.stringify(mapPoints).replace(/</g, '\\u003c')}></script>

    <Footer/>
</body>
</html>

<script>
    import L from 'leaflet';

    type MapPoint = { id: string; slug: string; title: string; price: number; image: string | null; lat: number; lng: number };

    const dataEl = document.getElementById('map-data');
    const points: MapPoint[] = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];

    const form  = document.querySelector<HTMLFormElement>('.filters-bar');
    const mapEl = document.getElementById('property-map');

    // Remember this results URL (with filters) so a property page can offer a
    // "back to results" link that returns to the exact same search.
    sessionStorage.setItem('havre:results-url', location.pathname + location.search);

    const nf = new Intl.NumberFormat('es-ES');
    const esc = (s: string) => s.replace(/[&<>"]/g, c => (
        { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string
    ));

    // ── Map: render the markers for the (already server-filtered) results ──
    if (mapEl && points.length > 0) {
        const map = L.map(mapEl, { scrollWheelZoom: false }).setView([43, 3], 5);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 18,
        }).addTo(map);

        const latlngs: L.LatLng[] = [];
        for (const p of points) {
            const icon = L.divIcon({
                className: 'price-marker',
                iconSize: undefined,
                html: `<span class="price-pill">€ ${nf.format(p.price)}</span>`,
            });
            const marker = L.marker([p.lat, p.lng], { icon }).addTo(map);
            marker.bindPopup(
                `<a class="map-popup" href="/comprar/${encodeURIComponent(p.slug)}">` +
                    (p.image ? `<span class="map-popup-img" style="background-image:url('${esc(p.image)}')"></span>` : '') +
                    `<span class="map-popup-body">` +
                        `<span class="map-popup-title">${esc(p.title)}</span>` +
                        `<span class="map-popup-price">€ ${nf.format(p.price)}</span>` +
                    `</span>` +
                `</a>`,
                { closeButton: false },
            );
            latlngs.push(marker.getLatLng());
        }
        if (latlngs.length) map.fitBounds(L.latLngBounds(latlngs), { padding: [40, 40], maxZoom: 13 });
    }

    // ── Search: submit navigates to a clean, shareable URL ──
    // Defaults are dropped so links stay tidy (e.g. /comprar?zona=toscana).
    if (form) {
        const buildUrl = () => {
            const fd = new FormData(form);
            const out = new URLSearchParams();
            const put = (key: string, raw: FormDataEntryValue | null, skip: string[]) => {
                const v = String(raw ?? '');
                if (v && !skip.includes(v)) out.set(key, v);
            };
            put('zona',    fd.get('zone'),      ['']);
            put('min',     fd.get('price-min'), ['', 'min']);
            put('max',     fd.get('price-max'), ['', 'max']);
            put('terreno', fd.get('surface'),   ['', 'any']);
            put('habs',    fd.get('rooms'),     ['']);
            put('order',   fd.get('sort'),      ['', 'featured']);
            const qs = out.toString();
            return qs ? `/comprar?${qs}` : '/comprar';
        };

        form.addEventListener('submit', e => {
            e.preventDefault();
            location.assign(buildUrl());
        });

        // Changing the sort applies immediately — it's cheap and expected.
        const sortSelect = form.querySelector('[name="sort"]') as HTMLSelectElement | null;
        sortSelect?.addEventListener('change', () => location.assign(buildUrl()));
    }
</script>

<style>
    main {
        padding: 0;
    }

    select {
        border: none;
        background: none;
        appearance: none;
        font-weight: var(--havre-weight-medium);
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-body);
    }

    .filters-bar {
        background-color: var(--havre-cornsilk);
        border-bottom: 1px solid var(--havre-border-card);
        padding: 16px 32px;
        width: 100%;
        position: sticky;
        z-index: 90;
        top: 75px;
    }

    .filters-primary {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        max-width: var(--max-width);
        margin-right: auto;
        margin-left: auto;
    }

    .filters-secondary {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
    }

    .filters-clear {
        cursor: pointer;
        background: none;
        border: none;
        text-decoration: underline;
        font-size: var(--havre-text-small);
        color: var(--havre-link);
        font-family: var(--havre-font-sans);
        font-weight: var(--havre-weight-semibold);
        white-space: nowrap;
    }

    .filters-search {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        padding: 13px 24px;
        border: none;
        border-radius: var(--havre-radius-md);
        background-color: var(--havre-bronze-default);
        color: var(--havre-white);
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-body);
        font-weight: var(--havre-weight-semibold);
        white-space: nowrap;
        transition: background 0.12s ease;
    }

    .filters-search:hover { background-color: var(--havre-bronze-hover); }
    .filters-search svg { width: 18px; height: 18px; }

    .filter-group {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background-color: white;
        border: 1px solid var(--havre-border-soft);
        padding: 12px 20px;
        border-radius: var(--havre-radius-md);

        label {
            font-size: var(--havre-text-label);
            font-weight: var(--havre-weight-semibold);
            letter-spacing: calc(var(--havre-tracking-label) *.5);
            color: var(--havre-text-faint);
        }
    }

    .filter.group {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .room-opts {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    fieldset {
        padding: 0px 10px !important;
        height: 45px;
    }

    .room-option {
        cursor: pointer;

        input[type="radio"] {
            display: none;
        }

        span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 34px;
            height: 28px;
            padding: 17px 12px;
            border-radius: var(--havre-radius-sm);
            font-size: var(--havre-text-small);
            font-weight: var(--havre-weight-medium);
            color: var(--havre-ink-700);
            user-select: none;
            transition: background 0.1s ease, color 0.1s ease, border-color 0.1s ease;
        }

        input[type="radio"]:checked + span {
            background: var(--havre-bronze-default);
            border-color: var(--havre-bronze-default);
            color: var(--havre-white);
            font-weight: var(--havre-weight-semibold);
        }
    }

    .content-layout {
        max-width: calc(var(--max-width) + 60px);
        margin-left: auto;
        margin-right: auto;
        padding: 25px 35px;
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 30px;
    }
    
    .map-panel {
        width: 100%;
        height: 700px;
        background-color: var(--havre-sage);
        position: sticky;
        top: 242px;
        border-radius: var(--havre-radius-xl);
        overflow: hidden;
    }

    #property-map {
        width: 100%;
        height: 100%;
    }

    .no-results {
        padding: 56px 0;
        text-align: center;
    }

    .no-results p {
        margin: 0 0 16px;
        font-size: var(--havre-text-body);
        color: var(--havre-ink-500);
    }

    .no-results-reset {
        font-size: var(--havre-text-small);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-bronze-text);
        text-decoration: underline;
    }

    .results-header {
        margin: 0 0 24px;
    }

    .results-header h1 {
        font-family: var(--havre-font-serif);
        font-size: var(--havre-text-h2);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-ink-900);
        line-height: var(--havre-leading-heading);
        margin: 0;
        display: flex;
        align-items: baseline;
        gap: 20px;
    }

    .results-count {
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-body);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-link);
    }

    .properties-grid {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding-bottom: 50px;
        gap: 20px;
    }

    .property-card {
        background-color: var(--havre-white);
        border: 1px solid var(--havre-border-card);
        border-radius: var(--havre-radius-lg);
        box-shadow: var(--havre-shadow-sm);
        transition: all ease-in 0.12s;
        overflow: hidden;
    }

    .property-card:hover {
        transform: translateY(-5px);
        border: 1px solid var(--havre-bronze-default);
        box-shadow: var(--havre-shadow-lg);
    }

    .property-image {
        display: block;
        position: relative;
        height: 180px;
        background: var(--img, repeating-linear-gradient(135deg, #E9EDC9 0 14px, #E1E6BC 14px 28px)) center / cover no-repeat;
    }

    .property-tag {
        position: absolute;
        top: 14px;
        left: 14px;
        margin: 0;
        font-size: var(--havre-text-label);
        font-weight: var(--havre-weight-semibold);
        letter-spacing: 0.04em;
        color: var(--havre-ink-900);
        background-color: var(--havre-cornsilk);
        padding: var(--havre-space-3) var(--havre-space-6);
        border-radius: var(--havre-radius-full);
    }

    .property-info {
        padding: 22px;
    }

    .property-location {
        margin: 0 0 6px;
        font-family: var(--havre-font-mono);
        text-transform: uppercase;
        font-size: 10px;
        letter-spacing: 0.04em;
        color: var(--havre-ink-300);
    }

    .property-title {
        margin: 0 0 14px;
        font-family: var(--havre-font-serif);
        font-weight: var(--havre-weight-semibold);
        line-height: 1.08;
        color: var(--havre-ink-900);
    }

    .property-specs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        list-style: none;
        margin: 0 0 18px;
        padding: 0;
    }

    .property-spec {
        font-size: var(--havre-text-label);
        font-weight: var(--havre-weight-medium);
        color: var(--havre-ink-700);
        background-color: var(--havre-chip-bg);
        border: 1px solid var(--havre-chip-border);
        padding: 5px 11px;
        border-radius: var(--havre-radius-sm);
    }

    .property-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 16px;
        border-top: 1px solid var(--havre-divider);
    }

    .property-price {
        margin: 0;
        font-family: var(--havre-font-serif);
        font-size: 25px;
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-bronze-text);
    }

    .property-link {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-bronze-text);
    }

    /* ── Tablet (≤ 959px) ── */
    @media (max-width: 959px) {
        .filters-bar { padding: 12px 20px; }

        .filters-primary {
            flex-wrap: nowrap;
            overflow-x: auto;
            gap: 10px;
            scrollbar-width: none;

            &::-webkit-scrollbar { display: none; }
        }

        .filter-group { padding: 10px 14px; flex-shrink: 0; }

        .filters-secondary { flex-shrink: 0; }

        .content-layout {
            grid-template-columns: 1fr;
            padding: 20px 24px;
            max-width: 720px;
        }

        .map-panel { display: none; }

        .properties-grid { grid-template-columns: 1fr 1fr; }

        .results-header h1 { font-size: var(--havre-text-h3); }
    }

    /* ── Mobile (≤ 559px) ── */
    @media (max-width: 559px) {
        .filters-bar { padding: 10px 16px; }

        .filter-group { padding: 8px 12px; gap: 8px; }

        .content-layout { padding: 16px; }

        .properties-grid { grid-template-columns: 1fr; }

        .results-header h1 { font-size: var(--havre-text-h3); }

        .property-image { height: 200px; }

        .property-info { padding: 16px; }
    }
</style>

<!-- Leaflet renders markers, popups and the container outside the component scope. -->
<style is:global>
    #property-map .leaflet-container {
        font-family: var(--havre-font-sans);
    }

    /* Reset Leaflet's default div-icon box; the pill provides its own look. */
    .price-marker.leaflet-div-icon {
        background: none;
        border: none;
        width: auto !important;
        height: auto !important;
        margin: 0 !important;
    }

    .price-pill {
        display: inline-block;
        transform: translate(-50%, -50%);
        padding: 5px 10px;
        border-radius: var(--havre-radius-full);
        background: var(--havre-white);
        border: 1px solid var(--havre-bronze-default);
        box-shadow: var(--havre-shadow-sm);
        font-family: var(--havre-font-sans);
        font-size: 13px;
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-ink-900);
