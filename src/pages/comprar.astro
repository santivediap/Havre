---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import "../styles/global.css"
import ArrowRight from "../components/icons/ArrowRight.astro"

const properties = [
    {
        tag:      "EN VENTA",
        location: "Toscana, Italia",
        title:    "Masía entre olivares",
        specs:    ["4 hab.", "2 baños", "320 m²"],
        price:    "685.000",
        slug:     "masia-entre-olivares",
    },
    {
        tag:      "NUEVO",
        location: "Provenza, Francia",
        title:    "Casa de piedra con viñedo",
        specs:    ["5 hab.", "3 baños", "410 m²"],
        price:    "920.000",
        slug:     "casa-de-piedra-con-vinedo",
    },
    {
        tag:      "DESTACADO",
        location: "Pirineos, España",
        title:    "Cortijo restaurado",
        specs:    ["3 hab.", "2 baños", "240 m²"],
        price:    "540.000",
        slug:     "cortijo-restaurado",
    },
    {
        tag:      "EN VENTA",
        location: "Alentejo, Portugal",
        title:    "Quinta con naranjos",
        specs:    ["6 hab.", "4 baños", "520 m²"],
        price:    "1.150.000",
        slug:     "quinta-con-naranjos",
    },
    {
        tag:      "NUEVO",
        location: "Umbría, Italia",
        title:    "Casale entre colinas",
        specs:    ["4 hab.", "3 baños", "300 m²"],
        price:    "795.000",
        slug:     "casale-entre-colinas",
    },
    {
        tag:      "EN VENTA",
        location: "Empordà, España",
        title:    "Casa rural de piedra",
        specs:    ["3 hab.", "2 baños", "280 m²"],
        price:    "620.000",
        slug:     "casa-rural-de-piedra",
    },
]

const zones = [
    { label: "Todas las zonas", value: ""          },
    { label: "Toscana",         value: "toscana"   },
    { label: "Provenza",        value: "provenza"  },
    { label: "Pirineos",        value: "pirineos"  },
    { label: "Alentejo",        value: "alentejo"  },
    { label: "Umbría",          value: "umbria"    },
    { label: "Empordà",         value: "emporda"   },
]

const pricesMin = [
    { label: "€ mín.",       value: "min"     },
    { label: "€ 100.000",    value: "100000"  },
    { label: "€ 200.000",    value: "200000"  },
    { label: "€ 300.000",    value: "300000"  },
    { label: "€ 500.000",    value: "500000"  },
    { label: "€ 750.000",    value: "750000"  },
    { label: "€ 1.000.000",  value: "1000000" },
]

const pricesMax = [
    { label: "€ máx.",       value: "max"      },
    { label: "€ 300.000",    value: "300000"   },
    { label: "€ 500.000",    value: "500000"   },
    { label: "€ 750.000",    value: "750000"   },
    { label: "€ 1.000.000",  value: "1000000"  },
    { label: "€ 1.500.000",  value: "1500000"  },
    { label: "€ 2.000.000",  value: "2000000"  },
]
const surfaces = [
    { label: "Cualquiera", value: "any"    },
    { label: "50 m²",      value: "50"  },
    { label: "100 m²",     value: "100" },
    { label: "150 m²",     value: "150" },
    { label: "200 m²",     value: "200" },
    { label: "300 m²",     value: "300" },
]
const roomOpts = [
    { label: "Todas", value: ""  },
    { label: "1+",    value: "1" },
    { label: "2+",    value: "2" },
    { label: "3+",    value: "3" },
    { label: "4+",    value: "4" },
    { label: "5+",    value: "5" },
]
const sortOpts = [
    { label: "Destacados",             value: "featured"   },
    { label: "Precio: menor a mayor",  value: "price-asc"  },
    { label: "Precio: mayor a menor",  value: "price-desc" },
    { label: "Más recientes",          value: "newest"     },
]
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comprar casa rural — Propiedades en venta | Havre</title>
    <meta name="description" content="Explora más de 340 casas de campo, masías, fincas y cortijos en venta en Toscana, Provenza, Pirineos, Alentejo y Empordà.">
</head>
<body>
    <Header/>

    <main>
        <form class="filters-bar" role="search" aria-label="Filtrar propiedades">
            <div class="filters-primary">
                <div class="filter-group">
                    <label for="filter-zone">ZONA</label>
                    <select id="filter-zone" name="zone">
                        { zones.map(z => <option value={z.value}>{z.label}</option>) }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-price-min">DESDE</label>
                    <select id="filter-price-min" name="price-min">
                        { pricesMin.map(p => <option value={p.value}>{p.label}</option>) }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-price-max">HASTA</label>
                    <select id="filter-price-max" name="price-max">
                        { pricesMax.map(p => <option value={p.value}>{p.label}</option>) }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="filter-surface">M² MÍN.</label>
                    <select id="filter-surface" name="surface">
                        { surfaces.map(s => <option value={s.value}>{s.label}</option>) }
                    </select>
                </div>

                <fieldset class="filter-group">
                    <label for="rooms">HAB.</label>
                    <div class="room-opts">
                        { roomOpts.map((opt, i) => (
                            <label class="room-option">
                                <input id="rooms" type="radio" name="rooms" value={opt.value} checked={i === 0} />
                                <span>{opt.label}</span>
                            </label>
                        )) }
                    </div>
                </fieldset>
                
                <div class="filters-secondary">
                    <button type="reset" class="filters-clear">Limpiar filtros</button>
                    <div class="filter-group">
                        <label for="filter-sort">ORDEN</label>
                        <select id="filter-sort" name="sort">
                            { sortOpts.map(o => <option value={o.value}>{o.label}</option>) }
                        </select>
                    </div>
                </div>
            </div>

        </form>

        <div class="content-layout">
            <section class="properties-panel" aria-label="Listado de propiedades">
                <header class="results-header">
                    <h1>Propiedades en venta <span class="results-count">{properties.length} resultados</span></h1>
                </header>

                <ul class="properties-grid" role="list">
                    { properties.map(property => (
                        <li>
                            <article class="property-card">
                                <div class="property-image">
                                    <p class="property-tag">{property.tag}</p>
                                </div>

                                <div class="property-info">
                                    <p class="property-location">{property.location}</p>
                                    <h2 class="property-title">{property.title}</h2>

                                    <ul class="property-specs" role="list">
                                        { property.specs.map(spec => (
                                            <li class="property-spec">{spec}</li>
                                        )) }
                                    </ul>

                                    <div class="property-footer">
                                        <p class="property-price">€ {property.price}</p>
                                        <a class="property-link" href={`/propiedades/${property.slug}`}>Ver ficha <ArrowRight/></a>
                                    </div>
                                </div>
                            </article>
                        </li>
                    )) }
                </ul>
            </section>

            <aside class="map-panel" aria-label="Mapa de propiedades">
            </aside>
        </div>
    </main>

    <Footer/>
</body>
</html>

<style>
    main {
        padding: 0;
    }

    select {
        border: none;
        background: none;
        appearance: none;
        font-weight: var(--havre-weight-medium);
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-body);
    }

    .filters-bar {
        background-color: var(--havre-cornsilk);
        border-bottom: 1px solid var(--havre-border-card);
        padding: 16px 32px;
        width: 100%;
        position: sticky;
        z-index: 90;
        top: 75px;
    }

    .filters-primary {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        max-width: var(--max-width);
        margin-right: auto;
        margin-left: auto;
    }

    .filters-secondary {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-left: auto;
    }

    .filters-clear {
        cursor: pointer;
        background: none;
        border: none;
        text-decoration: underline;
        font-size: var(--havre-text-small);
        color: var(--havre-link);
        font-family: var(--havre-font-sans);
        font-weight: var(--havre-weight-semibold);
    }

    .filter-group {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background-color: white;
        border: 1px solid var(--havre-border-soft);
        padding: 12px 20px;
        border-radius: var(--havre-radius-md);

        label {
            font-size: var(--havre-text-label);
            font-weight: var(--havre-weight-semibold);
            letter-spacing: calc(var(--havre-tracking-label) *.5);
            color: var(--havre-text-faint);
        }
    }

    .filter.group {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .room-opts {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    fieldset {
        padding: 0px 10px !important;
        height: 45px;
    }

    .room-option {
        cursor: pointer;

        input[type="radio"] {
            display: none;
        }

        span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 34px;
            height: 28px;
            padding: 17px 12px;
            border-radius: var(--havre-radius-sm);
            font-size: var(--havre-text-small);
            font-weight: var(--havre-weight-medium);
            color: var(--havre-ink-700);
            user-select: none;
            transition: background 0.1s ease, color 0.1s ease, border-color 0.1s ease;
        }

        input[type="radio"]:checked + span {
            background: var(--havre-bronze-default);
            border-color: var(--havre-bronze-default);
            color: var(--havre-white);
            font-weight: var(--havre-weight-semibold);
        }
    }

    .content-layout {
        max-width: calc(var(--max-width) + 60px);
        margin-left: auto;
        margin-right: auto;
        padding: 25px 35px;
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 30px;
    }
    
    .map-panel {
        width: 100%;
        height: 700px;
        background-color: var(--havre-sage);
        position: sticky;
        top: 242px;
        border-radius: var(--havre-radius-xl);
        padding: 28px 0px 0px;
    }

    .results-header {
        margin: 0 0 24px;
    }

    .results-header h1 {
        font-family: var(--havre-font-serif);
        font-size: var(--havre-text-h2);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-ink-900);
        line-height: var(--havre-leading-heading);
        margin: 0;
        display: flex;
        align-items: baseline;
        gap: 20px;
    }

    .results-count {
        font-family: var(--havre-font-sans);
        font-size: var(--havre-text-body);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-link);
    }

    .properties-grid {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        padding-bottom: 50px;
        gap: 20px;
    }

    .property-card {
        background-color: var(--havre-white);
        border: 1px solid var(--havre-border-card);
        border-radius: var(--havre-radius-lg);
        box-shadow: var(--havre-shadow-sm);
        transition: all ease-in 0.12s;
        overflow: hidden;
    }

    .property-card:hover {
        transform: translateY(-5px);
        border: 1px solid var(--havre-bronze-default);
        box-shadow: var(--havre-shadow-lg);
    }

    .property-image {
        position: relative;
        height: 180px;
        background-image: repeating-linear-gradient(135deg, #E9EDC9 0 14px, #E1E6BC 14px 28px);
    }

    .property-tag {
        position: absolute;
        top: 14px;
        left: 14px;
        margin: 0;
        font-size: var(--havre-text-label);
        font-weight: var(--havre-weight-semibold);
        letter-spacing: 0.04em;
        color: var(--havre-ink-900);
        background-color: var(--havre-cornsilk);
        padding: var(--havre-space-3) var(--havre-space-6);
        border-radius: var(--havre-radius-full);
    }

    .property-info {
        padding: 22px;
    }

    .property-location {
        margin: 0 0 6px;
        font-family: var(--havre-font-mono);
        text-transform: uppercase;
        font-size: 10px;
        letter-spacing: 0.04em;
        color: var(--havre-ink-300);
    }

    .property-title {
        margin: 0 0 14px;
        font-family: var(--havre-font-serif);
        font-weight: var(--havre-weight-semibold);
        line-height: 1.08;
        color: var(--havre-ink-900);
    }

    .property-specs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        list-style: none;
        margin: 0 0 18px;
        padding: 0;
    }

    .property-spec {
        font-size: var(--havre-text-label);
        font-weight: var(--havre-weight-medium);
        color: var(--havre-ink-700);
        background-color: var(--havre-chip-bg);
        border: 1px solid var(--havre-chip-border);
        padding: 5px 11px;
        border-radius: var(--havre-radius-sm);
    }

    .property-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 16px;
        border-top: 1px solid var(--havre-divider);
    }

    .property-price {
        margin: 0;
        font-family: var(--havre-font-serif);
        font-size: 25px;
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-bronze-text);
    }

    .property-link {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-bronze-text);
    }

    /* ── Tablet (≤ 959px) ── */
    @media (max-width: 959px) {
        .filters-bar { padding: 12px 20px; }

        .filters-primary {
            flex-wrap: nowrap;
            overflow-x: auto;
            gap: 10px;
            scrollbar-width: none;

            &::-webkit-scrollbar { display: none; }
        }

        .filter-group { padding: 10px 14px; flex-shrink: 0; }

        .filters-secondary { flex-shrink: 0; }

        .content-layout {
            grid-template-columns: 1fr;
            padding: 20px 24px;
            max-width: 720px;
        }

        .map-panel { display: none; }

        .properties-grid { grid-template-columns: 1fr 1fr; }

        .results-header h1 { font-size: var(--havre-text-h3); }
    }

    /* ── Mobile (≤ 559px) ── */
    @media (max-width: 559px) {
        .filters-bar { padding: 10px 16px; }

        .filter-group { padding: 8px 12px; gap: 8px; }

        .content-layout { padding: 16px; }

        .properties-grid { grid-template-columns: 1fr; }

        .results-header h1 { font-size: var(--havre-text-h3); }

        .property-image { height: 200px; }

        .property-info { padding: 16px; }
    }
</style>