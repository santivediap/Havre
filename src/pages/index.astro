---
import Header from "../components/Header.astro"
import Search from "../components/icons/Search.astro"
import Footer from "../components/Footer.astro"
import ArrowRight from "../components/icons/ArrowRight.astro"
import PropertyCard from "../components/PropertyCard.astro"
import { getZones } from "../services/zones"
import { getFeaturedProperties } from "../services/properties"

const surfaces = [
    { label: "Cualquiera", value: "any" },
    { label: "100 m²",     value: "100" },
    { label: "300 m²",     value: "300" },
    { label: "500 m²",     value: "500" }
]

const pricesMax = [
    { label: "€ máx.",       value: "max"      },
    { label: "€ 300.000",    value: "300000"   },
    { label: "€ 500.000",    value: "500000"   },
    { label: "€ 750.000",    value: "750000"   },
    { label: "€ 1.000.000",  value: "1000000"  },
    { label: "€ 1.500.000",  value: "1500000"  },
    { label: "€ 2.000.000",  value: "2000000"  },
]

const [zoneList, featured] = await Promise.all([getZones(), getFeaturedProperties()])
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

		<!-- preload hero image -->
		<link rel="preload" as="image" fetchpriority="high"
      	href="https://res.cloudinary.com/dqoqfb8vu/image/upload/w_1070/q_30/v1781375621/hero-bg_oflycq.webp">

	  	<!-- preconnect to images cdn -->
		<link rel="preconnect" href="https://res.cloudinary.com">

		<!-- connect to domain of font files -->
		<link rel="preconnect" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap' crossorigin>

		<!-- async CSS (optionally increase loading priority with fetchpriority="high") -->
		<link rel="preload" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap' onload="this.onload=null;this.rel='stylesheet';this.removeAttribute('as')" as="style">

		<!-- no-JS fallback -->
		<noscript>
			<link rel="stylesheet" href='https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap'>
		</noscript>
		<title>Astro</title>
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="hero-text-contents">
					<p class="hero-text">CASAS DE CAMPO · FINCAS · REFUGIOS</p>
					<h1 class="hero-title">Encuentra tu refugio entre campos dorados.</h1>
				</div>

				<form id="search-form" class="hero-search-form" action="">
					<div class="input">
						<label for="zone">ZONA</label>
						<select name="zone" id="zone">
							<option value="">Todas las zonas</option>
							{ zoneList.map(v => <option value={v.slug}>{v.name}</option>) }
						</select>
					</div>
					<div class="input input--separator">
						<label for="surface">M² MÍN.</label>
						<select name="surface" id="surface">
							{ surfaces.map(v => <option value={v.value}>{v.label}</option>) }
						</select>
					</div>
					<div class="input input--separator">
						<label for="price-max">HASTA</label>
						<select name="price-max" id="price-max">
							{ pricesMax.map(v => <option value={v.value}>{v.label}</option>) }
						</select>
					</div>

					<button type="submit"><Search/> Buscar</button>
				</form>

				<p class="subhero-text">+340 fincas y casas de campo · 12 regiones · acompañamiento personal de principio a fin</p>
			</section>

			<section class="properties-section">
				<h2 class="title">SELECCIÓN HAVRE</h2>
				<h1 class="main-title">Propiedades destacadas</h1>
				<a class="see-properties" href="comprar">Ver todas las propiedades</a>

				<div class="featured-properties">
					{ featured.map(property => <PropertyCard {...property} />) }
				</div>
			</section>
			<section class="properties-section">
				<h2 class="title">EXPLORA POR ZONA</h2>
				<h1 class="main-title">Cada región, su carácter</h1>
				<a class="explore-zones-link" href="/zonas">Explorar todas las zonas <ArrowRight/></a>

				<ul class="regions-grid">
					{ zoneList.map(zone => (
						<li class="region" style={zone.image_url ? `--img: url(${zone.image_url})` : undefined}>
							<a href={`/comprar?zona=${zone.slug}`}>
								<h3 class="region-name">{zone.name}</h3>
								<p class="region-count">{zone.count} propiedades</p>
							</a>
						</li>
					)) }
				</ul>
			</section>
			
			<section class="cta-section">
				<article class="cta-card cta-card--buyers">
					<p class="cta-label">COMPRADORES</p>
					<h2 class="cta-title">¿Buscas tu refugio en el campo?</h2>
					<p class="cta-text">Te acompañamos en cada paso: desde la primera visita hasta las llaves. Dinos qué imaginas y lo encontramos.</p>
					<a class="cta-btn cta-btn--bronze" href="comprar">Explorar propiedades</a>
				</article>
				<article class="cta-card cta-card--sellers">
					<p class="cta-label">VENDEDORES</p>
					<h2 class="cta-title">¿Quieres vender tu propiedad rural?</h2>
					<p class="cta-text">Valoramos tu casa de campo de forma gratuita y la presentamos al comprador adecuado, con cuidado y discreción.</p>
					<a class="cta-btn cta-btn--light" href="vender">Valora tu propiedad gratis</a>
				</article>
			</section>
		</main>

		<Footer/>
	</body>
</html>

<script>
	const form = document.getElementById("search-form") as HTMLFormElement;

	const buildUrl = () => {
		const fd = new FormData(form);
		const out = new URLSearchParams();
		const put = (key: string, raw: FormDataEntryValue | null, skip: string[]) => {
			const v = String(raw ?? '');
			if (v && !skip.includes(v)) out.set(key, v);
		};
		put('zona',    fd.get('zone'),      ['']);
		put('max',     fd.get('price-max'), ['', 'max']);
		put('terreno', fd.get('surface'),   ['', 'any']);
		const qs = out.toString();
		return qs ? `/comprar?${qs}` : '/comprar';
	};
	
	form.addEventListener("submit", (e) => {
		e.preventDefault()
		location.assign(buildUrl());
	})
</script>

<style>
  main {
    max-width: calc(var(--max-width) + 80px);
    padding: calc(var(--havre-space-5) * 4);
    margin: 0 auto;
  }

  .hero {
	margin-bottom: 180px;
    position: relative;
    border-radius: var(--havre-radius-2xl);
    width: 100%;
    height: 600px;
    background:
      linear-gradient(rgba(46, 42, 32, 0) 0%, rgba(46, 42, 32, 0) 60%, rgba(46, 42, 32, .8) 100%),
      linear-gradient(rgba(110, 122, 78, 0) 0%, rgba(101, 114, 70, .8) 30%, rgba(101, 114, 70, 1) 100%),
      url(https://res.cloudinary.com/dqoqfb8vu/image/upload/w_1070/q_30/v1781375621/hero-bg_oflycq.webp) center / cover no-repeat;
  }

  .hero-text-contents {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0 56px 92px;
  }

  .hero-text {
    margin: 0;
    color: var(--havre-cornsilk);
    font-size: var(--havre-text-small);
    letter-spacing: var(--havre-tracking-eyebrow);
    font-weight: var(--havre-weight-semibold);
  }

  .hero-title {
    margin: 0;
    color: var(--havre-cornsilk);
    font-family: var(--havre-font-serif);
    font-size: var(--havre-text-display);
    max-width: 700px;
  }

  .hero-search-form {
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
	border: 1px solid #eae3d0;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr auto;
    align-items: center;
    background-color: var(--havre-white);
    width: 100%;
    max-width: 1040px;
    padding: var(--havre-space-6) var(--havre-space-8);
    border-radius: var(--havre-radius-xl);
    box-shadow: var(--havre-shadow-xl);

    .input {
      padding: var(--havre-space-7) calc(var(--havre-space-1) * 10);

      label {
        display: block;
        font-size: var(--havre-text-label);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-text-faint);
        letter-spacing: calc(var(--havre-tracking-label) * .5);
        margin-bottom: 6px;
      }

      input, select {
        border: none;
        background: none;
        font-family: var(--havre-font-sans);
        padding: 0;
        font-weight: var(--havre-weight-medium);
        font-size: var(--havre-text-body);
        outline: none;
        appearance: none;
        width: 100%;
      }
    }

    .input--separator {
      border-left: 1px solid var(--havre-cream-border);
    }

    button {
      display: flex;
      align-items: center;
      gap: var(--havre-space-3);
      padding: 15px 30px;
      border-radius: var(--havre-radius-md);
      font-size: var(--havre-text-body);
      font-family: var(--havre-font-sans);
      font-weight: var(--havre-weight-semibold);
      background-color: var(--havre-bronze-default);
      border: none;
      color: var(--havre-white);
      cursor: pointer;
    }
  }

  .subhero-text {
    position: absolute;
    bottom: -95px;
    left: 50%;
    width: 100%;
    max-width: 800px;
    transform: translateX(-50%);
    text-align: center;
    font-size: var(--havre-text-small);
    color: var(--havre-ink-500);
  }

  .properties-section {
	position: relative;
	margin-bottom: 96px;
}

.see-properties {
	position: absolute;
	right: 0px;
	top: 60px;
	color: var(--havre-bronze-text);
	font-weight: var(--havre-weight-semibold);
	font-size: var(--havre-text-small);
}

.title {
	width: 100%;
	font-size: var(--havre-text-small);
	margin: 0px 0px var(--havre-space-7);
	letter-spacing: var(--havre-tracking-eyebrow);
	color: var(--havre-bronze-text);
}

.main-title {
	font-family: var(--havre-font-serif);
	font-size: var(--havre-text-h1);
	color: var(--havre-text);
	margin: 0 0 16px;
	font-weight: var(--havre-weight-semibold);
}

.explore-zones-link {
	display: flex;
	align-items: center;
	gap: 10px;
	font-size: var(--havre-text-small);
	font-weight: var(--havre-weight-semibold);
	color: var(--havre-bronze-text);
	margin-top: calc(var(--havre-space-5) * 2);
	margin-bottom: calc(var(--havre-space-5) * 3);
}

.featured-properties {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: calc(var(--havre-space-6) * 2);
}

.regions-grid {
	display: grid;
	grid-template-columns: repeat(5, 1fr);
	gap: 18px;
	list-style: none;
	margin: 0;
	padding: 0;
}

.region {
	height: 260px;
	border-radius: var(--havre-radius-lg);
	overflow: hidden;
	background:
		linear-gradient(rgba(46, 42, 32, 0) 0%, rgba(46, 42, 32, 0) 40%, rgba(46, 42, 32, 0.65) 100%),
		linear-gradient(rgba(110, 122, 78, 0) 0%, rgba(101, 114, 70, .15) 40%, rgba(101, 114, 70, .6) 100%),
		var(--img, repeating-linear-gradient(125deg, #CCD5AE 0 16px, #C3CDA1 16px 32px)) center / cover no-repeat;

	a {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		height: 100%;
		padding: 18px;
	}
}

.region:hover {
	filter: brightness(0.97);
}

.region-name {
	margin: 0 0 2px;
	font-family: var(--havre-font-serif);
	font-size: 22px;
	font-weight: var(--havre-weight-semibold);
	color: var(--havre-cornsilk);
}

.region-count {
	margin: 0;
	font-size: var(--havre-text-label);
	font-weight: var(--havre-weight-medium);
	color: rgba(254, 250, 224, 0.82);
}

.cta-section {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 24px;
	margin-bottom: 96px;
}

.cta-card {
	padding: 52px 48px;
	border-radius: var(--havre-radius-2xl);
}

.cta-card--buyers  { background-color: var(--havre-beige); }
.cta-card--sellers { background-color: var(--havre-ink-900); }

.cta-label {
	margin: 0 0 18px;
	font-size: var(--havre-text-label);
	font-weight: var(--havre-weight-semibold);
	letter-spacing: var(--havre-tracking-eyebrow);
}

.cta-card--buyers  .cta-label { color: #5E6B3A; }
.cta-card--sellers .cta-label { color: var(--havre-bronze); }

.cta-title {
	font-family: var(--havre-font-serif);
	font-size: var(--havre-text-h2);
	font-weight: var(--havre-weight-semibold);
	line-height: var(--havre-leading-heading);
	margin: 0 0 16px;
	max-width: 340px;
}

.cta-card--buyers  .cta-title { color: var(--havre-ink-900); }
.cta-card--sellers .cta-title { color: var(--havre-cornsilk); }

.cta-text {
	font-size: var(--havre-text-body);
	line-height: var(--havre-leading-body);
	margin: 0 0 32px;
	max-width: 370px;
}

.cta-card--buyers  .cta-text { color: var(--havre-ink-700); }
.cta-card--sellers .cta-text { color: var(--havre-ink-300); }

.cta-btn {
	display: inline-block;
	font-size: var(--havre-text-body);
	font-weight: var(--havre-weight-semibold);
	padding: 15px 30px;
	border-radius: var(--havre-radius-md);
	transition: all ease-in 0.15s;
}

.cta-btn:hover {
	transform: translateY(-3px);
}

.cta-btn--bronze {
	background-color: var(--havre-bronze-default);
	color: var(--havre-white);
}

.cta-btn--light {
	background-color: var(--havre-papaya);
	color: var(--havre-ink-900);
}

@media (max-width: 789px) {
  main { padding: 20px; }
  .hero {
    height: 420px;
    margin-bottom: 240px;
  }

  .hero-text-contents { padding: 0 28px 76px; }

  .hero-title { font-size: var(--havre-text-h1); }

  .hero-search-form {
    grid-template-columns: 1fr 1fr;
    bottom: -100px;
  }

  .hero-search-form > .input:nth-child(3) {
    border-left: none !important;
  }

  .subhero-text { bottom: -190px; }

  .see-properties {
    position: static;
    display: block;
    margin-bottom: 24px;
  }

  .featured-properties { grid-template-columns: 1fr 1fr; }

  .regions-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 480px) {
  main { padding: 16px; }

  .hero {
    height: 340px;
    margin-bottom: 320px;
  }

  .hero-text-contents { padding: 0 18px 66px; }

  .hero-title {
    font-size: 36px;
    max-width: 100%;
  }

  .hero-search-form {
    grid-template-columns: 1fr;
    bottom: -240px;
  }

  .input--separator {
	border-left: none !important;
    border-top: 1px solid var(--havre-cream-border);
  }

  .subhero-text { display: none; }

  .featured-properties { grid-template-columns: 1fr; }

  .regions-grid { grid-template-columns: 1fr 1fr; }

  .cta-section { grid-template-columns: 1fr; }

  .cta-card { padding: 36px 24px; }

  .cta-title { max-width: none; }
  .cta-text  { max-width: none; }
}
</style>
