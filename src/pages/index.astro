---
import Header from "../components/Header.astro"
import Search from "../components/icons/Search.astro"
import Footer from "../components/Footer.astro"
import ArrowRight from "../components/icons/ArrowRight.astro"

const regions = [
	{ name: "Toscana",  count: "84 propiedades" },
	{ name: "Provenza", count: "61 propiedades" },
	{ name: "Pirineos", count: "47 propiedades" },
	{ name: "Alentejo", count: "39 propiedades" },
	{ name: "Empordà",  count: "52 propiedades" },
]

const properties = [
	{ tag: "EN VENTA",   location: "TOSCANA, ITALIA",    title: "Masía entre olivares",       specs: ["4 hab.", "2 baños", "320 m²", "1.2 ha"], price: "€ 685.000"   },
	{ tag: "NUEVO",      location: "PROVENZA, FRANCIA",  title: "Casa de piedra con viñedo",  specs: ["5 hab.", "3 baños", "410 m²"],            price: "€ 920.000"   },
	{ tag: "DESTACADO",  location: "PIRINEOS, ESPAÑA",   title: "Cortijo restaurado",         specs: ["3 hab.", "2 baños", "240 m²"],            price: "€ 540.000"   },
	{ tag: "EN VENTA",   location: "ALENTEJO, PORTUGAL", title: "Quinta con naranjos",        specs: ["6 hab.", "4 baños", "520 m²", "3 ha"],    price: "€ 1.150.000" },
	{ tag: "NUEVO",      location: "UMBRÍA, ITALIA",     title: "Casale entre colinas",       specs: ["4 hab.", "3 baños", "360 m²"],            price: "€ 795.000"   },
	{ tag: "EN VENTA",   location: "EMPORDÀ, ESPAÑA",    title: "Casa rural de piedra",       specs: ["3 hab.", "2 baños", "280 m²", "0.8 ha"], price: "€ 620.000"   },
]
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="hero-text-contents">
					<p class="hero-text">CASAS DE CAMPO · FINCAS · REFUGIOS</p>
					<h1 class="hero-title">Encuentra tu refugio entre campos dorados.</h1>
				</div>

				<form class="hero-search-form" action="">
					<div class="input">
						<label for="zone">ZONA</label>
						<input type="text" name="zone" id="zone" placeholder="Toscana, Provenza, Pirineos...">
					</div>
					<div class="input input--separator">
						<label for="type">TIPO</label>
						<select name="type" id="type">
							<option value="all">Cualquiera</option>
							<option value="country-house">Casa de campo</option>
							<option value="farmhouse">Masía / Cortijo</option>
							<option value="property">Finca con terreno</option>
						</select>
					</div>
					<div class="input input--separator">
						<label for="price-max">PRECIO MÁX.</label>
						<select name="price-max" id="price-max">
							<option value="">Sin límite</option>
							<option value="">€ 500.000</option>
							<option value="">€ 750.000</option>
							<option value="">€ 1.000.000</option>
						</select>
					</div>

					<button type="submit"><Search/> Buscar</button>
				</form>

				<p class="subhero-text">+340 fincas y casas de campo · 12 regiones · acompañamiento personal de principio a fin</p>
			</section>

			<section class="properties-section">
				<h2 class="title">SELECCIÓN HAVRE</h2>
				<h1 class="main-title">Propiedades destacadas</h1>
				<a class="see-properties" href="comprar">Ver todas las propiedades</a>

				<div class="featured-properties">
					{ properties.map((property) => (
						<article class="property">
							<div class="property-image">
								<p class="property-tag">{property.tag}</p>
							</div>

							<div class="property-info">
								<p class="property-location">{property.location}</p>
								<h3 class="property-title">{property.title}</h3>
								<ul class="property-specs">
									{property.specs.map(spec => (
										<li class="property-spec">{spec}</li>
									))}
								</ul>
								<div class="property-footer">
									<p class="property-price">{property.price}</p>
									<a class="property-link" href="">Ver ficha</a>
								</div>
							</div>
						</article>
					)) }
				</div>
			</section>
			<section class="properties-section">
				<h2 class="title">EXPLORA POR ZONA</h2>
				<h1 class="main-title">Cada región, su carácter</h1>
				<a class="explore-zones-link" href="/zonas">Explorar todas las zonas <ArrowRight/></a>

				<ul class="regions-grid">
					{ regions.map(region => (
						<li class="region">
							<a href="">
								<h3 class="region-name">{region.name}</h3>
								<p class="region-count">{region.count}</p>
							</a>
						</li>
					)) }
				</ul>
			</section>
			
			<section class="cta-section">
				<article class="cta-card cta-card--buyers">
					<p class="cta-label">COMPRADORES</p>
					<h2 class="cta-title">¿Buscas tu refugio en el campo?</h2>
					<p class="cta-text">Te acompañamos en cada paso: desde la primera visita hasta las llaves. Dinos qué imaginas y lo encontramos.</p>
					<a class="cta-btn cta-btn--bronze" href="comprar">Explorar propiedades</a>
				</article>
				<article class="cta-card cta-card--sellers">
					<p class="cta-label">VENDEDORES</p>
					<h2 class="cta-title">¿Quieres vender tu propiedad rural?</h2>
					<p class="cta-text">Valoramos tu casa de campo de forma gratuita y la presentamos al comprador adecuado, con cuidado y discreción.</p>
					<a class="cta-btn cta-btn--light" href="vender">Valora tu propiedad gratis</a>
				</article>
			</section>
		</main>

		<Footer/>
	</body>
</html>

<style>
  main {
    max-width: calc(var(--max-width) + 80px);
    padding: calc(var(--havre-space-5) * 4);
    margin: 0 auto;
  }

  .hero {
	margin-bottom: 180px;
    position: relative;
    border-radius: var(--havre-radius-2xl);
    width: 100%;
    height: 600px;
    background:
      linear-gradient(rgba(46, 42, 32, 0) 0%, rgba(46, 42, 32, 0) 60%, rgba(46, 42, 32, .8) 100%),
      linear-gradient(rgba(110, 122, 78, 0) 0%, rgba(101, 114, 70, .8) 30%, rgba(101, 114, 70, 1) 100%),
      url(https://res.cloudinary.com/dqoqfb8vu/image/upload/v1781375621/hero-bg_oflycq.webp) center / cover no-repeat;
  }

  .hero-text-contents {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0 56px 92px;
  }

  .hero-text {
    margin: 0;
    color: var(--havre-cornsilk);
    font-size: var(--havre-text-small);
    letter-spacing: var(--havre-tracking-eyebrow);
    font-weight: var(--havre-weight-semibold);
  }

  .hero-title {
    margin: 0;
    color: var(--havre-cornsilk);
    font-family: var(--havre-font-serif);
    font-size: var(--havre-text-display);
    max-width: 700px;
  }

  .hero-search-form {
    position: absolute;
    bottom: -40px;
    left: 50%;
    transform: translateX(-50%);
	border: 1px solid #eae3d0;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr auto;
    align-items: center;
    background-color: var(--havre-white);
    width: 100%;
    max-width: 1040px;
    padding: var(--havre-space-6) var(--havre-space-8);
    border-radius: var(--havre-radius-xl);
    box-shadow: var(--havre-shadow-xl);

    .input {
      padding: var(--havre-space-7) calc(var(--havre-space-1) * 10);

      label {
        display: block;
        font-size: var(--havre-text-label);
        font-weight: var(--havre-weight-semibold);
        color: var(--havre-text-faint);
        letter-spacing: calc(var(--havre-tracking-label) * .5);
        margin-bottom: 6px;
      }

      input, select {
        border: none;
        background: none;
        font-family: var(--havre-font-sans);
        padding: 0;
        font-weight: var(--havre-weight-medium);
        font-size: var(--havre-text-body);
        outline: none;
        appearance: none;
        width: 100%;
      }
    }

    .input--separator {
      border-left: 1px solid var(--havre-cream-border);
    }

    button {
      display: flex;
      align-items: center;
      gap: var(--havre-space-3);
      padding: 15px 30px;
      border-radius: var(--havre-radius-md);
      font-size: var(--havre-text-body);
      font-family: var(--havre-font-sans);
      font-weight: var(--havre-weight-semibold);
      background-color: var(--havre-bronze-default);
      border: none;
      color: var(--havre-white);
      cursor: pointer;
    }
  }

  .subhero-text {
    position: absolute;
    bottom: -95px;
    left: 50%;
    width: 100%;
    max-width: 800px;
    transform: translateX(-50%);
    text-align: center;
    font-size: var(--havre-text-small);
    color: var(--havre-ink-500);
  }

  .properties-section {
	position: relative;
	margin-bottom: 96px;
}

.see-properties {
	position: absolute;
	right: 0px;
	top: 60px;
	color: var(--havre-bronze-text);
	font-weight: var(--havre-weight-semibold);
	font-size: var(--havre-text-small);
}

.title {
	width: 100%;
	font-size: var(--havre-text-small);
	margin: 0px 0px var(--havre-space-7);
	letter-spacing: var(--havre-tracking-eyebrow);
	color: var(--havre-bronze-text);
}

.main-title {
	font-family: var(--havre-font-serif);
	font-size: var(--havre-text-h1);
	color: var(--havre-text);
	margin: 0 0 16px;
	font-weight: var(--havre-weight-semibold);
}

.explore-zones-link {
	display: flex;
	align-items: center;
	gap: 10px;
	font-size: var(--havre-text-small);
	font-weight: var(--havre-weight-semibold);
	color: var(--havre-bronze-text);
	margin-top: calc(var(--havre-space-5) * 2);
	margin-bottom: calc(var(--havre-space-5) * 3);
}

.featured-properties {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: calc(var(--havre-space-6) * 2);
}

.property {
	background-color: var(--havre-white);
	border: 1px solid var(--havre-border-card);
	border-radius: var(--havre-radius-lg);
	box-shadow: var(--havre-shadow-sm);
	transition: all ease-in 0.15s;
	overflow: hidden;
}

.property:hover {
	transform: translateY(-3px);
}

.property-image {
	position: relative;
	height: 210px;
	background-image: repeating-linear-gradient(135deg, #E9EDC9 0 14px, #E1E6BC 14px 28px);
}

.property-tag {
	position: absolute;
	top: 14px;
	left: 14px;
	margin: 0;
	font-size: var(--havre-text-label);
	font-weight: var(--havre-weight-semibold);
	letter-spacing: 0.04em;
	color: var(--havre-ink-900);
	background-color: var(--havre-cornsilk);
	padding: var(--havre-space-3) var(--havre-space-6);
	border-radius: var(--havre-radius-full);
}

.property-info {
	padding: 22px;
}

.property-location {
	margin: 0 0 6px;
	font-family: var(--havre-font-mono);
	font-size: 11px;
	letter-spacing: 0.04em;
	color: var(--havre-ink-300);
}

.property-title {
	margin: 0 0 14px;
	font-family: var(--havre-font-serif);
	font-size: 27px;
	font-weight: var(--havre-weight-semibold);
	line-height: 1.08;
	color: var(--havre-ink-900);
}

.property-specs {
	display: flex;
	flex-wrap: wrap;
	gap: 8px;
	list-style: none;
	margin: 0 0 18px;
	padding: 0;
}

.property-spec {
	font-size: var(--havre-text-label);
	font-weight: var(--havre-weight-medium);
	color: var(--havre-ink-700);
	background-color: var(--havre-chip-bg);
	border: 1px solid var(--havre-chip-border);
	padding: 5px 11px;
	border-radius: var(--havre-radius-sm);
}

.property-footer {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding-top: 16px;
	border-top: 1px solid var(--havre-divider);
}

.property-price {
	margin: 0;
	font-family: var(--havre-font-serif);
	font-size: 25px;
	font-weight: var(--havre-weight-semibold);
	color: var(--havre-bronze-text);
}

.property-link {
	font-size: 13px;
	font-weight: var(--havre-weight-semibold);
	color: var(--havre-bronze-text);
}

.regions-grid {
	display: grid;
	grid-template-columns: repeat(5, 1fr);
	gap: 18px;
	list-style: none;
	margin: 0;
	padding: 0;
}

.region {
	height: 260px;
	border-radius: var(--havre-radius-lg);
	overflow: hidden;
	background-image: repeating-linear-gradient(125deg, #CCD5AE 0 16px, #C3CDA1 16px 32px);

	a {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		height: 100%;
		padding: 18px;
		background: linear-gradient(180deg, rgba(46, 42, 32, 0) 45%, rgba(46, 42, 32, 0.62) 100%);
	}
}

.region:hover {
	filter: brightness(0.97);
}

.region-name {
	margin: 0 0 2px;
	font-family: var(--havre-font-serif);
	font-size: 22px;
	font-weight: var(--havre-weight-semibold);
	color: var(--havre-cornsilk);
}

.region-count {
	margin: 0;
	font-size: var(--havre-text-label);
	font-weight: var(--havre-weight-medium);
	color: rgba(254, 250, 224, 0.82);
}

.cta-section {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 24px;
	margin-bottom: 96px;
}

.cta-card {
	padding: 52px 48px;
	border-radius: var(--havre-radius-2xl);
}

.cta-card--buyers  { background-color: var(--havre-beige); }
.cta-card--sellers { background-color: var(--havre-ink-900); }

.cta-label {
	margin: 0 0 18px;
	font-size: var(--havre-text-label);
	font-weight: var(--havre-weight-semibold);
	letter-spacing: var(--havre-tracking-eyebrow);
}

.cta-card--buyers  .cta-label { color: #5E6B3A; }
.cta-card--sellers .cta-label { color: var(--havre-bronze); }

.cta-title {
	font-family: var(--havre-font-serif);
	font-size: var(--havre-text-h2);
	font-weight: var(--havre-weight-semibold);
	line-height: var(--havre-leading-heading);
	margin: 0 0 16px;
	max-width: 340px;
}

.cta-card--buyers  .cta-title { color: var(--havre-ink-900); }
.cta-card--sellers .cta-title { color: var(--havre-cornsilk); }

.cta-text {
	font-size: var(--havre-text-body);
	line-height: var(--havre-leading-body);
	margin: 0 0 32px;
	max-width: 370px;
}

.cta-card--buyers  .cta-text { color: var(--havre-ink-700); }
.cta-card--sellers .cta-text { color: var(--havre-ink-300); }

.cta-btn {
	display: inline-block;
	font-size: var(--havre-text-body);
	font-weight: var(--havre-weight-semibold);
	padding: 15px 30px;
	border-radius: var(--havre-radius-md);
	transition: all ease-in 0.15s;
}

.cta-btn:hover {
	transform: translateY(-3px);
}

.cta-btn--bronze {
	background-color: var(--havre-bronze-default);
	color: var(--havre-white);
}

.cta-btn--light {
	background-color: var(--havre-papaya);
	color: var(--havre-ink-900);
}

@media (max-width: 789px) {
  main { padding: 20px; }
  .hero {
    height: 420px;
    margin-bottom: 240px;
  }

  .hero-text-contents { padding: 0 28px 76px; }

  .hero-title { font-size: var(--havre-text-h1); }

  .hero-search-form {
    grid-template-columns: 1fr 1fr;
    bottom: -100px;
  }

  .hero-search-form > .input:nth-child(3) {
    border-left: none !important;
  }

  .subhero-text { bottom: -190px; }

  .see-properties {
    position: static;
    display: block;
    margin-bottom: 24px;
  }

  .featured-properties { grid-template-columns: 1fr 1fr; }

  .regions-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 480px) {
  main { padding: 16px; }

  .hero {
    height: 340px;
    margin-bottom: 320px;
  }

  .hero-text-contents { padding: 0 18px 66px; }

  .hero-title {
    font-size: 36px;
    max-width: 100%;
  }

  .hero-search-form {
    grid-template-columns: 1fr;
    bottom: -240px;
  }

  .input--separator {
	border-left: none !important;
    border-top: 1px solid var(--havre-cream-border);
  }

  .subhero-text { display: none; }

  .featured-properties { grid-template-columns: 1fr; }

  .regions-grid { grid-template-columns: 1fr 1fr; }

  .cta-section { grid-template-columns: 1fr; }

  .cta-card { padding: 36px 24px; }

  .cta-title { max-width: none; }
  .cta-text  { max-width: none; }
}
</style>
