---
import "../styles/global.css"
import Lock from "./icons/Lock.astro"
import { getSession } from "../lib/auth"
const { pathname } = Astro.url
const session = await getSession(Astro.cookies)
---

<header>
    <div class="header-box">
        <a class="logo-link" href="/">Havre</a>

        <nav>
            <a href="comprar" class={pathname === "/comprar" ? "nav-active" : ""}>Comprar</a>
            <a href="vender" class={pathname === "/vender" ? "nav-active" : ""}>Vender</a>
            <a href="zonas" class={pathname === "/zonas" ? "nav-active" : ""}>Zonas</a>
            <a href="about-us" class={pathname === "/about-us" ? "nav-active" : ""}>Sobre Havre</a>
        </nav>

        <div class="right-header">
            { session ? (
                <a class="header-panel" href="/admin"><Lock /> Panel de administración</a>
            ) : (
                <Fragment>
                    <a class="header-login" href="login">Acceder</a>
                    <a class={`cta-header${pathname === "/vender" ? " cta-header--active" : ""}`}
                       href={pathname === "/vender" ? "/vender#valorar" : "/vender"}>
                        {pathname === "/vender" ? "Valorar mi casa" : "Vender mi casa"}
                    </a>
                </Fragment>
            ) }
        </div>
    </div>
</header>

<style>
  header {
    position: sticky;
    top: 0px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--havre-border);
    background-color: rgba(251, 249, 240, 0.9);
    z-index: 100;
    backdrop-filter: blur(12px);
    padding: 0 calc(var(--havre-space-5) * 4);
    width: 100%;
    height: 76px;
  }

  .header-box {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-link {
    font-family: var(--havre-font-serif);
    color: var(--havre-ink-900);
    font-weight: var(--havre-weight-bold);
    font-size: var(--havre-text-h3);
  }

  nav {
    display: flex;
    gap: calc(var(--havre-space-6) * 3);

    a {
      font-weight: var(--havre-weight-medium);
      color: var(--havre-ink-700);
    }

    a.nav-active {
      color: var(--havre-bronze-text);
      font-weight: var(--havre-weight-semibold);
    }
  }

  .right-header {
    display: flex;
    align-items: center;
    gap: var(--havre-space-8);

    .header-login {
      color: var(--havre-ink-700);
      font-weight: var(--havre-weight-semibold);
    }

    .cta-header {
      font-size: var(--havre-text-small);
      color: var(--havre-bronze-text);
      font-weight: var(--havre-weight-medium);
      border: 1px solid var(--havre-bronze-default);
      border-radius: var(--havre-radius-md);
      padding: var(--havre-space-5) calc(var(--havre-space-5) * 2);
      transition: background-color 0.16s ease, color 0.16s ease;
    }

    .cta-header--active {
      background-color: var(--havre-bronze-default);
      color: var(--havre-white);
      font-weight: var(--havre-weight-semibold);
      border-color: var(--havre-bronze-default);
    }

    .header-panel {
      display: flex;
      align-items: center;
      gap: var(--havre-space-4);
      font-size: var(--havre-text-small);
      font-weight: var(--havre-weight-semibold);
      color: var(--havre-bronze-text);
      background-color: var(--havre-bronze-soft);
      border-radius: var(--havre-radius-md);
      padding: var(--havre-space-5) calc(var(--havre-space-5) * 2);
      transition: background-color 0.16s ease;
    }

    .header-panel:hover { background-color: var(--havre-papaya); }
  }

  @media (max-width: 789px) {
    header { padding: 0 20px; }
    nav { display: none; }
  }
</style>
